        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compila la posizione automaticamente mentre sei in casa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "住まいにいる間に位置情報を自動入力します。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completează locația automat cât timp ești la locuință."
