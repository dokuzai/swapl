    "Your points balance, history, and gifting — stay somewhere without a simultaneous swap." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "رصيد نقاطك وسجلها وإهداؤها — أقم في مكان دون تبادل متزامن."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "رصيد نقاطك، وسجلها، والإهداء — أُسكن بمكان بدون تبديل بنفس الوقت."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το υπόλοιπο πόντων, το ιστορικό και η δωρεά σας — μείνετε κάπου χωρίς ταυτόχρονη ανταλλαγή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu saldo de puntos, historial y regalos — alójate en algún sitio sin un intercambio simultáneo."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "موجودی امتیاز، تاریخچه و هدیه دادن شما — جایی اقامت کنید بدون مبادله همزمان."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre solde de points, votre historique et vos cadeaux — séjournez quelque part sans échange simultané."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saldo poin, riwayat, dan pemberian hadiah Anda — menginap di suatu tempat tanpa tukaran bersamaan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo saldo punti, la cronologia e i regali — soggiorna da qualche parte senza uno scambio simultaneo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポイント残高、履歴、贈り物 — 同時のスワップなしでどこかに滞在できます。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soldul, istoricul și dăruirea punctelor tale — stai undeva fără un schimb simultan."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ยอดพอยต์ ประวัติ และการมอบพอยต์ของคุณ — เข้าพักที่ไหนสักแห่งโดยไม่ต้องแลกเปลี่ยนพร้อมกัน"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puan bakiyen, geçmişin ve hediye etme — eş zamanlı bir takas olmadan bir yerde konakla."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的积分余额、记录和赠送——无需同时互换即可入住某处。"
          }
        }
      }
    },
