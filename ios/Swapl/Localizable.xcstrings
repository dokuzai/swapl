    "This removes your proposal. You can always send a new one.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuove la tua proposta. Puoi sempre inviarne una nuova."
          }
        }
      }
    },
    "This step is completely optional. Upload a document that shows this is your home — your deed or title if you own it, or your lease agreement if you rent. A recent utility bill in your name works too.": {
      "localizations": {
        "it": {
          "stringUnit": {
