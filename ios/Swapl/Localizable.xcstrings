    "A passkey uses Face ID or Touch ID and syncs with iCloud Keychain. It can't be phished or guessed." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم مفتاح المرور Face ID أو Touch ID ويُزامَن مع سلسلة مفاتيح iCloud. لا يمكن التصيّد به أو تخمينه."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مفتاح المرور بيستخدم Face ID أو Touch ID وبيتزامن مع iCloud Keychain. ما بينسرق ولا بينحزر."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ένα passkey χρησιμοποιεί Face ID ή Touch ID και συγχρονίζεται με το iCloud Keychain. Δεν μπορεί να υποκλαπεί ή να μαντευτεί."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una clave de acceso usa Face ID o Touch ID y se sincroniza con el Llavero de iCloud. No se puede suplantar ni adivinar."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "گذرکلید از Face ID یا Touch ID استفاده می‌کند و با iCloud Keychain همگام می‌شود. قابل فیشینگ یا حدس زدن نیست."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une clé d'accès utilise Face ID ou Touch ID et se synchronise avec le trousseau iCloud. Elle ne peut être ni hameçonnée ni devinée."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passkey memakai Face ID atau Touch ID dan tersinkron dengan iCloud Keychain. Tidak bisa dibobol phishing atau ditebak."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una passkey usa Face ID o Touch ID e si sincronizza con il Portachiavi iCloud. Non può essere rubata con il phishing né indovinata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パスキーはFace IDまたはTouch IDを使い、iCloudキーチェーンと同期します。フィッシングや推測の対象になりません。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O cheie de acces folosește Face ID sau Touch ID și se sincronizează cu iCloud Keychain. Nu poate fi furată prin phishing sau ghicită."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "พาสคีย์ใช้ Face ID หรือ Touch ID และซิงค์กับ iCloud Keychain ไม่สามารถถูกหลอกลวงหรือคาดเดาได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geçiş anahtarı Face ID veya Touch ID kullanır ve iCloud Anahtar Zinciri ile eşitlenir. Oltalanamaz veya tahmin edilemez."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通行密钥使用 Face ID 或 Touch ID，并与 iCloud 钥匙串同步，无法被钓鱼或猜测。"
          }
        }
      }
    },
    "A private room is worth fewer Keys per night than offering the whole home." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تساوي الغرفة الخاصة مفاتيح أقل في الليلة مقارنةً بعرض المنزل بالكامل."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الغرفة الخاصة بتساوي مفاتيح أقل بالليلة من ما تقدّم البيت كامل."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ένα ιδιωτικό δωμάτιο αξίζει λιγότερα Keys ανά νύχτα από την προσφορά ολόκληρου του σπιτιού."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una habitación privada vale menos Llaves por noche que ofrecer la casa entera."
