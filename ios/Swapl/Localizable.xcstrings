        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accettare questo scambio?"
          }
        }
      }
    },
    "Accepting issues the swap insurance policy for both homes and creates a binding agreement.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accettando viene emessa la polizza assicurativa dello scambio per entrambe le case e si crea un accordo vincolante."
          }
        }
      }
    },
    "Add a city.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi una città."
