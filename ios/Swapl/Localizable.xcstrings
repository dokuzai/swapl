    "+%@": {
      "comment": "A badge that shows the amount of Keys",
      "isCommentAutoGenerated": true
    },
    "A friend": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un amico"
          }
        }
      }
    },
    "A guest gets one room rather than your whole home, so the nightly value is scaled to match. That keeps it fair next to whole-home stays.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un ospite riceve una stanza anziché tutta la casa, quindi il valore per notte è ridotto di conseguenza. Così resta equo rispetto ai soggiorni in case intere."
          }
        }
      }
    },
    "A member": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un membro"
          }
        }
      }
    },
    "A passkey uses Face ID or Touch ID and syncs with iCloud Keychain. It can't be phished or guessed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una passkey usa Face ID o Touch ID e si sincronizza con il Portachiavi iCloud. Non può essere rubata con il phishing né indovinata."
          }
        }
      }
    },
    "A tamper-proof record that your cover is real — not crypto, no payment, nothing for you to do.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una prova a prova di manomissione che la tua copertura è reale — niente cripto, nessun pagamento, niente da fare per te."
          }
        }
      }
    },
    "A trust boost for guests. Never required to publish or swap.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un segnale di fiducia per gli ospiti. Mai obbligatorio per pubblicare o scambiare."
          }
        }
      }
    },
    "About this home": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Informazioni sulla casa"
          }
        }
      }
    },
