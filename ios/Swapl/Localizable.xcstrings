        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "به محض اینکه مبادله‌ها در شهر شما باز شوند، به شما ایمیل می‌زنیم."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
