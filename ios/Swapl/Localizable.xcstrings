    "Add a clearer title.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un titolo più chiaro."
          }
        }
      }
    },
    "Add a co-traveler in seconds. They can chat here, but only you and your swap partner can accept, counter, or cancel the swap.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un co-viaggiatore in pochi secondi. Può chattare qui, ma solo tu e il tuo partner di scambio potete accettare, controproporre o annullare lo scambio."
          }
        }
      }
    },
