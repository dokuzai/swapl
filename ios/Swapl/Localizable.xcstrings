    "Booked on our partners' sites at their prices — swapl may earn a commission, never a markup." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُحجَز على مواقع شركائنا بأسعارهم — قد يكسب swapl عمولة، لكن دون أي زيادة في السعر."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بينحجز على مواقع شركائنا بأسعارهم — ممكن swapl تاخد عمولة، بس أبداً مش زيادة سعر."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κρατήσεις στους ιστότοπους των συνεργατών μας στις τιμές τους — η swapl μπορεί να κερδίσει προμήθεια, ποτέ προσαύξηση."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reservado en los sitios de nuestros socios a sus precios — swapl puede ganar una comisión, nunca un recargo."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "در سایت‌های شرکای ما با قیمت‌های آن‌ها رزرو می‌شود — swapl ممکن است کمیسیون بگیرد، اما هرگز قیمت را افزایش نمی‌دهد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réservé sur les sites de nos partenaires à leurs prix — swapl peut percevoir une commission, jamais de majoration."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dipesan di situs mitra kami dengan harga mereka — swapl mungkin mendapat komisi, tak pernah menaikkan harga."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prenotato sui siti dei nostri partner ai loro prezzi — swapl può guadagnare una commissione, mai un sovrapprezzo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パートナーのサイトでその価格で予約されます。swaplは手数料を得ることはあっても、上乗せはしません。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rezervat pe site-urile partenerilor noștri la prețurile lor — swapl poate câștiga un comision, niciodată un adaos."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "จองบนเว็บไซต์ของพาร์ทเนอร์ในราคาของพวกเขา — swapl อาจได้รับค่าคอมมิชชัน แต่ไม่เคยบวกราคาเพิ่ม"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İş ortaklarımızın sitelerinde kendi fiyatlarıyla rezerve edilir — swapl komisyon kazanabilir, asla fiyat farkı değil."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在合作伙伴网站以其原价预订——swapl 可能赚取佣金，绝不加价。"
          }
        }
      }
    },
