        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یک اتاق خصوصی هر شب کلید کمتری نسبت به ارائه کل خانه دارد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une chambre privée vaut moins de Clés par nuit que de proposer tout le logement."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamar privat bernilai lebih sedikit Keys per malam dibanding menawarkan seluruh rumah."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una stanza privata vale meno Chiavi a notte rispetto all'intera casa."
