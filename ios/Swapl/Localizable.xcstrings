    "We read every response — it directly shapes what we build next." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نقرأ كل رد — فهو يشكّل مباشرةً ما نبنيه تالياً."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "منقرأ كل ردّ — بيأثّر مباشرة على إيش بنبني بعدين."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Διαβάζουμε κάθε απάντηση — διαμορφώνει άμεσα αυτό που φτιάχνουμε στη συνέχεια."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leemos todas las respuestas — influyen directamente en lo que construimos a continuación."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ما هر پاسخ را می‌خوانیم — مستقیماً آنچه را بعداً می‌سازیم شکل می‌دهد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous lisons chaque réponse — elle façonne directement ce que nous construisons ensuite."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kami membaca setiap tanggapan — ini langsung memengaruhi apa yang kami bangun selanjutnya."
