    "Listening — speak freely, tap the mic again to stop." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نستمع — تحدّث بحرية، اضغط الميكروفون مرة أخرى للتوقف."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عم نسمع — احكِ براحتك، دوس على المايك كمان مرة عشان توقف."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ακούω — μιλήστε ελεύθερα, πατήστε ξανά το μικρόφωνο για διακοπή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escuchando — habla con libertad, toca el micrófono de nuevo para parar."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "در حال شنیدن — آزادانه صحبت کنید، برای توقف دوباره روی میکروفون ضربه بزنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À l'écoute — parlez librement, touchez à nouveau le micro pour arrêter."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mendengarkan — bicaralah dengan bebas, ketuk mik lagi untuk berhenti."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In ascolto — parla liberamente, tocca di nuovo il microfono per fermarti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "聞き取り中 — 自由にお話しください。マイクをもう一度タップすると停止します。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascult — vorbește liber, atinge din nou microfonul pentru a opri."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
