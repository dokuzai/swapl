    "Tap a check-in then a check-out inside the home's availability. %@–%@ nights. Taken dates are greyed out." : {
      "comment" : "A description of the availability calendar. The first argument is the minimum number of nights the host can accommodate. The second argument is the maximum number of nights.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على تاريخ وصول ثم مغادرة ضمن توفر المنزل. %1$@–%2$@ ليالٍ. التواريخ المحجوزة باهتة."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دوس تاريخ دخول وبعدين خروج جوّا توفّر البيت. %1$@–%2$@ ليلة. التواريخ المحجوزة بتطلع رمادية."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πατήστε ένα check-in και μετά ένα check-out εντός της διαθεσιμότητας του σπιτιού. %1$@–%2$@ νύχτες. Οι κατειλημμένες ημερομηνίες εμφανίζονται γκριζαρισμένες."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap a check-in then a check-out inside the home's availability. %1$@–%2$@ nights. Taken dates are greyed out."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca una entrada y luego una salida dentro de la disponibilidad de la casa. %1$@–%2$@ noches. Las fechas ocupadas aparecen atenuadas."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یک تاریخ ورود و سپس یک تاریخ خروج را در محدوده در دسترس بودن خانه ضربه بزنید. %1$@ تا %2$@ شب. تاریخ‌های اشغال‌شده خاکستری شده‌اند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez une arrivée puis un départ dans la disponibilité du logement. %1$@–%2$@ nuits. Les dates prises sont grisées."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ketuk check-in lalu check-out dalam ketersediaan rumah. %1$@–%2$@ malam. Tanggal yang sudah terisi tampak pudar."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca un check-in poi un check-out entro la disponibilità della casa. %1$@–%2$@ notti. Le date occupate sono in grigio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "住まいの空き期間内でチェックイン、続いてチェックアウトをタップしてください。%1$@〜%2$@泊。予約済みの日付はグレー表示されます。"
          }
        },
        "ro" : {
          "stringUnit" : {
