    "Your points are held until the host confirms. Track it under Trips." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُحتجَز نقاطك حتى يؤكد المضيف. تتبّعها ضمن الرحلات."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نقاطك محجوزة لحد ما المستضيف يأكّد. تابعها تحت الرحلات."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι πόντοι σας κρατούνται μέχρι ο οικοδεσπότης να επιβεβαιώσει. Παρακολουθήστε το στα Ταξίδια."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus puntos quedan retenidos hasta que el anfitrión confirme. Haz su seguimiento en Viajes."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امتیازهای شما تا زمان تأیید میزبان نگه داشته می‌شوند. آن را در بخش سفرها دنبال کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos points sont retenus jusqu'à ce que l'hôte confirme. Suivez cela dans Voyages."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poin Anda ditahan sampai tuan rumah mengonfirmasi. Lacak di Perjalanan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tuoi punti restano bloccati finché l'host non conferma. Segui tutto in Viaggi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポイントはホストが確定するまで保留されます。「旅行」で確認できます。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Punctele tale sunt reținute până când gazda confirmă. Urmărește-le la Călătorii."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "พอยต์ของคุณถูกพักไว้จนกว่าเจ้าของที่พักจะยืนยัน ติดตามได้ใต้เมนูทริป"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puanların, ev sahibi onaylayana kadar tutulur. Bunu Seyahatler altından takip et."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的积分将冻结至房东确认。可在“行程”中跟踪。"
          }
        }
      }
    },
