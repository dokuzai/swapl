    "Pick a start and end date above to block them." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر تاريخ بدء وانتهاء أعلاه لحجبهما."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختار تاريخ بداية ونهاية فوق عشان تحجبهم."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Επιλέξτε μια ημερομηνία έναρξης και λήξης παραπάνω για να τις αποκλείσετε."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige arriba una fecha de inicio y de fin para bloquearlas."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برای مسدود کردن، یک تاریخ شروع و پایان در بالا انتخاب کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez une date de début et de fin ci-dessus pour les bloquer."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilih tanggal mulai dan akhir di atas untuk memblokirnya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli una data di inizio e una di fine qui sopra per bloccarle."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ブロックするには、上で開始日と終了日を選んでください。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alege o dată de început și una de sfârșit mai sus pentru a le bloca."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เลือกวันเริ่มต้นและวันสิ้นสุดด้านบนเพื่อบล็อก"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kapatmak için yukarıdan bir başlangıç ve bitiş tarihi seç."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在上方选择开始和结束日期以屏蔽它们。"
          }
        }
      }
    },
