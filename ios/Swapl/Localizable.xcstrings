    "You've reached your plan's listing limit. Upgrade to publish more homes." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد بلغت حد العروض في خطتك. قم بالترقية لنشر المزيد من المنازل."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وصلت لحدّ الإعلانات بخطتك. رقّي عشان تنشر بيوت أكتر."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Φτάσατε το όριο καταχωρίσεων του προγράμματός σας. Αναβαθμίστε για να δημοσιεύσετε περισσότερα σπίτια."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has alcanzado el límite de anuncios de tu plan. Mejora tu plan para publicar más casas."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "به محدودیت آگهی پلن خود رسیده‌اید. برای انتشار خانه‌های بیشتر ارتقا دهید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez atteint la limite d'annonces de votre forfait. Passez à une offre supérieure pour publier plus de logements."
