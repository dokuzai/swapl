    "Allow location access to prefill your home details." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسمح بالوصول إلى الموقع لتعبئة تفاصيل منزلك مسبقاً."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسمح بالوصول للموقع عشان نعبّي تفاصيل بيتك تلقائياً."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Επιτρέψτε την πρόσβαση στην τοποθεσία για προσυμπλήρωση των στοιχείων του σπιτιού σας."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite el acceso a la ubicación para rellenar los datos de tu casa."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برای پر کردن خودکار جزئیات خانه‌تان، دسترسی به موقعیت را مجاز کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorisez l'accès à la localisation pour préremplir les détails de votre logement."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izinkan akses lokasi untuk mengisi otomatis detail rumah Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consenti l'accesso alla posizione per precompilare i dettagli della tua casa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置情報へのアクセスを許可して住まいの詳細を自動入力します。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite accesul la locație pentru a precompleta detaliile locuinței tale."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "อนุญาตการเข้าถึงตำแหน่งเพื่อกรอกรายละเอียดบ้านล่วงหน้า"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ev bilgilerini önceden doldurmak için konum erişimine izin ver."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许定位访问，以自动填写你家的信息。"
          }
        }
      }
    },
    "Almost there" : {
      "localizations" : {
        "ar" : {
