    "A friend" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "صديق"
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "صاحب"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ένας φίλος"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un amigo"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یک دوست"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ami"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seorang teman"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un amico"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "友人"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un prieten"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เพื่อนคนหนึ่ง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir arkadaş"
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一位好友"
          }
        }
      }
    },
    "A guest gets one room rather than your whole home, so the nightly value is scaled to match. That keeps it fair next to whole-home stays." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحصل الضيف على غرفة واحدة بدلاً من منزلك بالكامل، لذا تُعدَّل القيمة الليلية لتناسب ذلك. وهذا يبقيها عادلة مقارنةً بإقامات المنزل الكامل."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الضيف بياخد غرفة وحدة مش البيت كله، فقيمة الليلة بتتعدّل عشان تناسب. هيك بتظل عادلة جنب اللي بيأجّروا البيت كامل."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ο επισκέπτης παίρνει ένα δωμάτιο αντί για ολόκληρο το σπίτι σας, οπότε η αξία ανά νύχτα προσαρμόζεται ανάλογα. Έτσι παραμένει δίκαιο σε σχέση με τις διαμονές σε ολόκληρο σπίτι."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El huésped recibe una habitación en lugar de toda tu casa, por lo que el valor por noche se ajusta en consecuencia. Así es justo frente a las estancias de casa completa."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مهمان یک اتاق می‌گیرد نه کل خانه شما، بنابراین ارزش هر شب متناسب با آن تنظیم می‌شود. این کار آن را در کنار اقامت در کل خانه منصفانه نگه می‌دارد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un voyageur obtient une chambre plutôt que tout votre logement, la valeur par nuit est donc ajustée en conséquence. Cela reste équitable par rapport aux logements entiers."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tamu mendapat satu kamar, bukan seluruh rumah Anda, jadi nilai per malam disesuaikan. Ini menjaga keadilan dibandingkan inap satu rumah penuh."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ospite riceve una stanza anziché tutta la casa, quindi il valore per notte è ridotto di conseguenza. Così resta equo rispetto ai soggiorni in case intere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ゲストは住まい全体ではなく1部屋を利用するため、1泊あたりの価値もそれに合わせて調整されます。これにより住まい全体の滞在と公平に保たれます。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un oaspete primește o cameră, nu întreaga locuință, așa că valoarea pe noapte este ajustată corespunzător. Astfel rămâne echitabil față de sejururile în întreaga locuință."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ผู้เข้าพักได้เพียงหนึ่งห้องแทนที่จะเป็นบ้านทั้งหลัง มูลค่าต่อคืนจึงถูกปรับให้สอดคล้องกัน ซึ่งช่วยให้ยุติธรรมเมื่อเทียบกับการเข้าพักทั้งบ้าน"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Misafir, evinin tamamı yerine bir oda kullanır; bu yüzden gecelik değer buna göre ölçeklenir. Böylece tüm ev konaklamalarının yanında adil kalır."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "房客入住的是一个房间而非整套住所，因此每晚价值会按比例调整，与整套出租保持公平。"
          }
        }
      }
    },
    "A member" : {
      "extractionState" : "stale",
      "localizations" : {
