    "End date must be after start date." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجب أن يكون تاريخ الانتهاء بعد تاريخ البدء."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تاريخ النهاية لازم يكون بعد تاريخ البداية."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η ημερομηνία λήξης πρέπει να είναι μετά την ημερομηνία έναρξης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fecha de fin debe ser posterior a la de inicio."
          }
        },
