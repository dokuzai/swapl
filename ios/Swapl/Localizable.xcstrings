    "Share how the stay with %@ went — it helps the next guest." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شارك كيف سارت الإقامة مع %@ — فهذا يساعد الضيف التالي."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شارك كيف كانت الإقامة مع %@ — بتساعد الضيف الجاي."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μοιραστείτε πώς πήγε η διαμονή με %@ — βοηθά τον επόμενο επισκέπτη."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuenta qué tal fue la estancia con %@ — ayuda al próximo huésped."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بگویید اقامت با %@ چطور بود — به مهمان بعدی کمک می‌کند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partagez comment s'est passé le séjour avec %@ — cela aide le prochain voyageur."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bagikan bagaimana inap dengan %@ berjalan — ini membantu tamu berikutnya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Racconta com'è andato il soggiorno con %@ — aiuta il prossimo ospite."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@との滞在がどうだったか共有してください。次のゲストの役に立ちます。"
