    "Passkey saved. Next time, pick “Sign in with a passkey” on the login screen." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم حفظ مفتاح المرور. في المرة القادمة، اختر “تسجيل الدخول بمفتاح مرور” في شاشة الدخول."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انحفظ مفتاح المرور. المرة الجاية، اختار “سجّل دخول بمفتاح مرور” بشاشة الدخول."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
