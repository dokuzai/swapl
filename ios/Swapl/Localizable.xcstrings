    "This removes your proposal. You can always send a new one." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي هذا إلى إزالة اقتراحك. يمكنك دائماً إرسال اقتراح جديد."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هاد بيشيل اقتراحك. بتقدر دايماً تبعت واحد جديد."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αυτό αφαιρεί την πρότασή σας. Μπορείτε πάντα να στείλετε μια νέα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina tu propuesta. Siempre puedes enviar una nueva."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "این پیشنهاد شما را حذف می‌کند. همیشه می‌توانید یک پیشنهاد جدید ارسال کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime votre proposition. Vous pouvez toujours en envoyer une nouvelle."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini menghapus usulan Anda. Anda selalu bisa mengirim yang baru."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo rimuove la tua proposta. Puoi sempre inviarne una nuova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
