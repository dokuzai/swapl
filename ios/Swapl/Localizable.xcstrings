          }
        }
      }
    },
    "We sent a 6-digit code to %@. It expires in 10 minutes." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أرسلنا رمزاً من 6 أرقام إلى %@. ينتهي خلال 10 دقائق."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
