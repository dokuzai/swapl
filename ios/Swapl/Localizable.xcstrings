        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accesso alla posizione è disattivato per Swapl. Inserisci l'indirizzo manualmente o attivalo nelle Impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swaplの位置情報アクセスがオフになっています。住所を手動で入力するか、設定で有効にしてください。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accesul la locație este dezactivat pentru Swapl. Introdu adresa manual sau activează-l în Setări."
