    "Location access is off for Swapl. Enter the address manually or enable it in Settings." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الوصول إلى الموقع معطّل لـ Swapl. أدخل العنوان يدوياً أو فعّله في الإعدادات."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الوصول للموقع مقفّل لـ Swapl. اكتب العنوان يدوي أو فعّله من الإعدادات."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η πρόσβαση στην τοποθεσία είναι απενεργοποιημένη για τη Swapl. Εισαγάγετε τη διεύθυνση χειροκίνητα ή ενεργοποιήστε τη στις Ρυθμίσεις."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la ubicación está desactivado para Swapl. Introduce la dirección manualmente o actívalo en Ajustes."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دسترسی به موقعیت برای Swapl خاموش است. آدرس را به‌صورت دستی وارد کنید یا آن را در تنظیمات فعال کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la localisation est désactivé pour Swapl. Saisissez l'adresse manuellement ou activez-le dans les Réglages."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akses lokasi mati untuk Swapl. Masukkan alamat secara manual atau aktifkan di Pengaturan."
