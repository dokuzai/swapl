          }
        }
      }
    },
    "The other host will be notified. This can't be undone.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'altro host verrà avvisato. L'operazione non può essere annullata."
          }
        }
      }
    },
    "They'll lose access to this conversation. You can invite them again anytime.": {
      "localizations": {
