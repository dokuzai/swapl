    "Please confirm you have the right to host before publishing." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرجى تأكيد أن لديك الحق في الاستضافة قبل النشر."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أكّد إنه عندك الحق تستضيف قبل ما تنشر."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Επιβεβαιώστε ότι έχετε το δικαίωμα να φιλοξενείτε πριν τη δημοσίευση."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirma que tienes derecho a hospedar antes de publicar."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لطفاً قبل از انتشار تأیید کنید که حق میزبانی دارید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez confirmer que vous avez le droit d'accueillir avant de publier."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mohon konfirmasi bahwa Anda berhak menjamu sebelum mempublikasikan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conferma di avere il diritto di ospitare prima di pubblicare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公開する前に、ホストする権利があることを確認してください。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te rugăm să confirmi că ai dreptul să găzduiești înainte de publicare."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "โปรดยืนยันว่าคุณมีสิทธิ์เป็นเจ้าของที่พักก่อนเผยแพร่"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
