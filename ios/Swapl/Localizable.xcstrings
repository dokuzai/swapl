          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هنگامی که در خانه هستید، موقعیت را به‌طور خودکار پر کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
