    "Up to %@ per gift, %@ per day. Points are a gift — they can't be bought or cashed out." : {
      "comment" : "A footer that describes the maximum number of points that can be gifted, the daily limit, and that points are a gift.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حتى %1$@ لكل هدية، و%2$@ في اليوم. النقاط هدية — لا يمكن شراؤها أو صرفها نقداً."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لحد %1$@ بالهدية، %2$@ باليوم. النقاط هدية — ما بتنشترى ولا بتنصرّف."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Έως %1$@ ανά δώρο, %2$@ ανά ημέρα. Οι πόντοι είναι δώρο — δεν μπορούν να αγοραστούν ή να εξαργυρωθούν."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Up to %1$@ per gift, %2$@ per day. Points are a gift — they can't be bought or cashed out."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hasta %1$@ por regalo, %2$@ al día. Los puntos son un regalo — no se pueden comprar ni canjear por efectivo."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حداکثر %1$@ در هر هدیه، %2$@ در روز. امتیازها یک هدیه هستند — قابل خرید یا نقد کردن نیستند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jusqu'à %1$@ par cadeau, %2$@ par jour. Les points sont un cadeau — ils ne peuvent être ni achetés ni encaissés."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hingga %1$@ per hadiah, %2$@ per hari. Poin adalah hadiah — tidak bisa dibeli atau dicairkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fino a %1$@ per regalo, %2$@ al giorno. I punti sono un regalo — non possono essere acquistati né incassati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1回の贈り物につき最大%1$@、1日につき最大%2$@。ポイントは贈り物であり、購入も換金もできません。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Până la %1$@ per cadou, %2$@ pe zi. Punctele sunt un cadou — nu pot fi cumpărate sau încasate."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "สูงสุด %1$@ ต่อการมอบหนึ่งครั้ง %2$@ ต่อวัน พอยต์คือของขวัญ — ซื้อหรือถอนเป็นเงินไม่ได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hediye başına %1$@, gün başına %2$@ kadar. Puanlar bir hediyedir — satın alınamaz veya nakde çevrilemez."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每次赠送最多 %1$@，每天最多 %2$@。积分是一份礼物——无法购买或兑现。"
          }
        }
      }
    },
