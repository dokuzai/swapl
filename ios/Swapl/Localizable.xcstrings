    "Add an email to auto-match the invite when they sign up, or leave it blank for an open link anyone can use." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف بريداً إلكترونياً لمطابقة الدعوة تلقائياً عند تسجيلهم، أو اتركه فارغاً لرابط مفتوح يمكن لأي شخص استخدامه."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ضيف إيميل عشان الدعوة تتطابق لحالها لمّا يسجّلوا، أو اتركه فاضي عشان رابط مفتوح أي حدا يقدر يستخدمه."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Προσθέστε ένα email για αυτόματη αντιστοίχιση της πρόσκλησης κατά την εγγραφή, ή αφήστε το κενό για ανοιχτό σύνδεσμο που μπορεί να χρησιμοποιήσει οποιοσδήποτε."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade un correo para vincular la invitación automáticamente cuando se registren, o déjalo en blanco para un enlace abierto que cualquiera pueda usar."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یک ایمیل اضافه کنید تا هنگام ثبت‌نام دعوت به‌طور خودکار تطبیق داده شود، یا برای یک لینک باز که هر کسی می‌تواند استفاده کند، آن را خالی بگذارید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez un e-mail pour associer automatiquement l'invitation lors de l'inscription, ou laissez vide pour un lien ouvert utilisable par tous."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tambahkan email untuk mencocokkan undangan otomatis saat mereka mendaftar, atau biarkan kosong untuk tautan terbuka yang bisa dipakai siapa saja."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi un'email per abbinare automaticamente l'invito alla registrazione, oppure lascia vuoto per un link aperto utilizzabile da chiunque."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メールアドレスを追加すると登録時に招待が自動でマッチします。空欄のままにすると、誰でも使えるオープンなリンクになります。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaugă un e-mail pentru a potrivi automat invitația la înscriere sau lasă-l necompletat pentru un link deschis pe care îl poate folosi oricine."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เพิ่มอีเมลเพื่อจับคู่คำเชิญอัตโนมัติเมื่อพวกเขาสมัคร หรือเว้นว่างไว้สำหรับลิงก์เปิดที่ใครก็ใช้ได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaydolduklarında daveti otomatik eşleştirmek için bir e-posta ekle veya herkesin kullanabileceği açık bir bağlantı için boş bırak."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
