    "Save the dates you're dreaming about. The assistant composes swaps from real homes that are free exactly then." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احفظ التواريخ التي تحلم بها. يُنشئ المساعد تبادلات من منازل حقيقية متاحة في ذلك الوقت بالضبط."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احفظ التواريخ اللي بتحلم فيها. المساعد بيجهّز تبديلات من بيوت حقيقية فاضية بالضبط بهديك الأيام."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αποθηκεύστε τις ημερομηνίες που ονειρεύεστε. Ο βοηθός συνθέτει ανταλλαγές από πραγματικά σπίτια που είναι διαθέσιμα ακριβώς τότε."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarda las fechas con las que sueñas. El asistente compone intercambios con casas reales libres justo entonces."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تاریخ‌هایی را که در آرزویشان هستید ذخیره کنید. دستیار از خانه‌های واقعی که دقیقاً در آن زمان خالی هستند، مبادله می‌سازد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez les dates dont vous rêvez. L'assistant compose des échanges à partir de vrais logements libres précisément à ce moment-là."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simpan tanggal yang Anda impikan. Asisten menyusun tukaran dari rumah nyata yang kosong tepat saat itu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
