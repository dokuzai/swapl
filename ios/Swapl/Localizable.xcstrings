    "Keys for keys — share this with your guest so they can get in." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مفاتيح مقابل مفاتيح — شارك هذا مع ضيفك حتى يتمكن من الدخول."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مفاتيح بمفاتيح — شارك هاد مع ضيفك عشان يفوت."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keys για κλειδιά — μοιραστείτε το με τον επισκέπτη σας ώστε να μπορεί να μπει."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Llaves por llaves — comparte esto con tu huésped para que pueda entrar."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کلید در برابر کلید — این را با مهمانتان به اشتراک بگذارید تا بتواند وارد شود."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des clés contre des Clés — partagez ceci avec votre voyageur pour qu'il puisse entrer."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keys for keys — bagikan ini ke tamu Anda agar mereka bisa masuk."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiavi per chiavi — condividilo con il tuo ospite così può entrare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鍵には鍵を — これをゲストと共有して、中に入れるようにしましょう。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chei pentru chei — distribuie asta oaspetelui tău ca să poată intra."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keys แลก keys — แชร์สิ่งนี้ให้ผู้เข้าพักเพื่อให้เข้าได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anahtara anahtar — misafirinin içeri girebilmesi için bunu onunla paylaş."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以钥匙换钥匙——把这个分享给房客，让他们进门。"
          }
        }
      }
    },
