          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Συμπληρώστε αυτόματα την τοποθεσία όσο βρίσκεστε στο σπίτι."
          }
        },
        "es" : {
          "stringUnit" : {
