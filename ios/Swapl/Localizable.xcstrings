          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kami akan mengemail Anda begitu tukaran dibuka di kota Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
