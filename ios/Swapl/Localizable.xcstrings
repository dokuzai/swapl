          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เราจะส่งอีเมลหาคุณทันทีที่การแลกเปลี่ยนเปิดในเมืองของคุณ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şehrinde takaslar açıldığı an sana e-posta göndereceğiz."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你所在城市一开放互换，我们就会邮件通知你。"
          }
        }
      }
    },
