    "Maximum stay must be at least the minimum stay." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجب ألا تقل مدة الإقامة القصوى عن مدة الإقامة الدنيا."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أطول إقامة لازم تكون على الأقل زي أقصر إقامة."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η μέγιστη διαμονή πρέπει να είναι τουλάχιστον ίση με την ελάχιστη διαμονή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La estancia máxima debe ser al menos igual a la mínima."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حداکثر اقامت باید حداقل برابر با حداقل اقامت باشد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le séjour maximum doit être au moins égal au séjour minimum."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inap maksimum harus minimal sama dengan inap minimum."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il soggiorno massimo deve essere almeno pari al minimo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最長滞在日数は最短滞在日数以上にしてください。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sejurul maxim trebuie să fie cel puțin cât sejurul minim."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การเข้าพักสูงสุดต้องไม่น้อยกว่าการเข้าพักขั้นต่ำ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maksimum konaklama, en az minimum konaklama kadar olmalı."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最长入住时间不得短于最短入住时间。"
          }
        }
      }
    },
