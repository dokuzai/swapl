    "Unlike a swap, the host doesn't travel to you. You spend travel points you earned by hosting — never money." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بخلاف التبادل، لا يسافر المضيف إليك. تنفق نقاط سفر كسبتها بالاستضافة — وليس نقوداً أبداً."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عكس التبديل، المستضيف ما بيسافر لعندك. إنت بتصرف نقاط سفر كسبتها بالاستضافة — أبداً مش مصاري."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Σε αντίθεση με μια ανταλλαγή, ο οικοδεσπότης δεν ταξιδεύει σε εσάς. Ξοδεύετε πόντους ταξιδιού που κερδίσατε φιλοξενώντας — ποτέ χρήματα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A diferencia de un intercambio, el anfitrión no viaja a tu casa. Gastas puntos de viaje que ganaste hospedando — nunca dinero."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برخلاف مبادله، میزبان به نزد شما سفر نمی‌کند. شما امتیازهای سفری را که با میزبانی کسب کرده‌اید خرج می‌کنید — هرگز پول."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contrairement à un échange, l'hôte ne voyage pas chez vous. Vous dépensez des points de voyage gagnés en accueillant — jamais de l'argent."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berbeda dengan tukaran, tuan rumah tidak datang ke Anda. Anda memakai poin perjalanan yang diperoleh dengan menjamu — bukan uang."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A differenza di uno scambio, l'host non viaggia da te. Spendi punti viaggio guadagnati ospitando — mai denaro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スワップとは異なり、ホストがあなたのところに来ることはありません。ホストして獲得したトラベルポイントを使います — お金ではありません。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spre deosebire de un schimb, gazda nu călătorește la tine. Cheltuiești puncte de călătorie câștigate prin găzduire — niciodată bani."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ต่างจากการแลกเปลี่ยน เจ้าของที่พักไม่ได้เดินทางมาหาคุณ คุณใช้พอยต์เดินทางที่ได้รับจากการเป็นเจ้าของที่พัก — ไม่ใช่เงิน"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir takastan farklı olarak, ev sahibi sana gelmez. Ev sahipliği yaparak kazandığın seyahat puanlarını harcarsın — asla para değil."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与互换不同，房东不会前往你处。你花费的是接待所赚得的旅行积分——绝非金钱。"
          }
        }
      }
    },
    "Unlocks %@ — 48h before your stay." : {
