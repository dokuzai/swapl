        }
      }
    },
    "Unlike a swap, the host doesn't travel to you. You spend travel points you earned by hosting — never money.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "A differenza di uno scambio, l'host non viaggia da te. Spendi punti viaggio guadagnati ospitando — mai denaro."
          }
        }
      }
    },
    "Unlocks %@ — 48h before your stay.": {
      "comment": "A label that describes when the address unlocks. The argument is a date.",
