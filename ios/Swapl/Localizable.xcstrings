    "Confirming the swap for %@ issues the swap insurance policy for both homes. This creates a binding agreement." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي تأكيد التبادل في %@ إلى إصدار وثيقة تأمين التبادل لكلا المنزلين. وهذا ينشئ اتفاقاً ملزماً."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لمّا تأكّد التبديل لـ %@ بتطلع وثيقة تأمين التبديل للبيتين. هاد بيعمل اتفاق مُلزِم."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η επιβεβαίωση της ανταλλαγής για %@ εκδίδει το ασφαλιστήριο ανταλλαγής για τα δύο σπίτια. Αυτό δημιουργεί μια δεσμευτική συμφωνία."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirmar el intercambio para %@ emite la póliza de seguro del intercambio para ambas casas. Esto crea un acuerdo vinculante."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تأیید مبادله برای %@، بیمه‌نامه مبادله را برای هر دو خانه صادر می‌کند. این یک توافق الزام‌آور ایجاد می‌کند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirmer l'échange pour %@ émet la police d'assurance d'échange pour les deux logements. Cela crée un accord contraignant."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengonfirmasi tukaran untuk %@ menerbitkan polis asuransi tukaran untuk kedua rumah. Ini membentuk perjanjian yang mengikat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confermando lo scambio per %@ viene emessa la polizza assicurativa per entrambe le case. Si crea un accordo vincolante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@のスワップを確定すると、両方の住まいにスワップ保険が発行されます。これにより拘束力のある契約が成立します。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirmarea schimbului pentru %@ emite polița de asigurare a schimbului pentru ambele locuințe. Aceasta creează un acord obligatoriu."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การยืนยันการแลกเปลี่ยนสำหรับ %@ จะออกกรมธรรม์ประกันการแลกเปลี่ยนสำหรับทั้งสองบ้าน ซึ่งสร้างข้อตกลงที่มีผลผูกพัน"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ için takası onaylamak, her iki ev için takas sigortası poliçesini başlatır. Bu, bağlayıcı bir anlaşma oluşturur."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确认 %@ 的互换将为双方住所签发互换保险，并生成一份具有约束力的协议。"
          }
        }
      }
    },
