    "Accepting issues the swap insurance policy for both homes and creates a binding agreement." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي القبول إلى إصدار وثيقة تأمين التبادل لكلا المنزلين وينشئ اتفاقاً ملزماً."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لمّا تقبل بتطلع وثيقة تأمين التبديل للبيتين وبيصير اتفاق مُلزِم."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η αποδοχή εκδίδει το ασφαλιστήριο ανταλλαγής για τα δύο σπίτια και δημιουργεί μια δεσμευτική συμφωνία."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al aceptar se emite la póliza de seguro del intercambio para ambas casas y se crea un acuerdo vinculante."
          }
        },
        "fa" : {
