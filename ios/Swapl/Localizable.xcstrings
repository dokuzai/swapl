    "Real catalogue prices. Untick anything you don't want — you'll only be charged if the host accepts your swap." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أسعار الكتالوج الحقيقية. ألغِ تحديد أي شيء لا تريده — لن تُحاسَب إلا إذا قبل المضيف تبادلك."
          }
        },
        "ar-PS" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أسعار الكتالوج الحقيقية. شيل علامة أي إشي ما بدّك إياه — بتنحاسب بس إذا المستضيف قبل تبديلك."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πραγματικές τιμές καταλόγου. Αποεπιλέξτε ό,τι δεν θέλετε — θα χρεωθείτε μόνο αν ο οικοδεσπότης αποδεχτεί την ανταλλαγή σας."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Precios reales de catálogo. Desmarca lo que no quieras — solo se te cobrará si el anfitrión acepta tu intercambio."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قیمت‌های واقعی کاتالوگ. تیک هر چیزی را که نمی‌خواهید بردارید — فقط در صورتی هزینه می‌شوید که میزبان مبادله شما را بپذیرد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prix réels du catalogue. Décochez ce que vous ne voulez pas — vous ne serez débité que si l'hôte accepte votre échange."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harga katalog asli. Hilangkan centang apa pun yang tidak Anda inginkan — Anda hanya ditagih jika tuan rumah menerima tukaran Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prezzi reali da catalogo. Deseleziona ciò che non vuoi — ti verrà addebitato solo se l'host accetta il tuo scambio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "実際のカタログ価格です。不要なものはチェックを外してください。請求されるのはホストがスワップを承認した場合のみです。"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prețuri reale din catalog. Debifează orice nu vrei — vei fi taxat doar dacă gazda îți acceptă schimbul."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ราคาตามแคตตาล็อกจริง ยกเลิกการเลือกสิ่งที่คุณไม่ต้องการ — คุณจะถูกเรียกเก็บเงินเฉพาะเมื่อเจ้าของที่พักยอมรับการแลกเปลี่ยนของคุณ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gerçek katalog fiyatları. İstemediğin her şeyin işaretini kaldır — yalnızca ev sahibi takasını kabul ederse ücretlendirilirsin."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "真实目录价。取消勾选不想要的项——只有房东接受你的互换时才会收费。"
          }
        }
      }
    },
