{
  "name": "@swapl/api-spec",
  "version": "0.1.0",
  "private": true,
  "description": "OpenAPI contract for the Swapl API — single source of truth for web/iOS/Android client types.",
  "types": "generated/ts/schema.d.ts",
  "exports": {
    ".": {
      "types": "./generated/ts/schema.d.ts"
    }
  },
  "files": [
    "openapi.yaml",
    "generated"
  ],
  "scripts": {
    "gen:ts": "openapi-typescript openapi.yaml -o generated/ts/schema.d.ts && cp generated/ts/schema.d.ts ../../app/lib/generated/api-schema.d.ts",
    "gen:swift-spec": "cp openapi.yaml ../swapl-api-client/Sources/SwaplAPIClient/openapi.yaml",
    "generate": "pnpm run gen:ts && pnpm run gen:swift-spec",
    "check:drift": "node scripts/check-route-drift.mjs"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0"
  }
}
