// swapl — Prisma schema
// SQLite for local dev. Switch provider to "postgresql" + DATABASE_URL for prod.
// SQLite limitations honored: no native enums, no scalar arrays — both stored as JSON-encoded TEXT.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- USER ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  avatar       String?
  bio          String?
  passwordHash String?
  verified     Boolean  @default(false)
  // Inbox-confirmed email. Distinct from `verified` (the listing-trust KYC
  // badge). Set when the user clicks the link in the verification email.
  emailVerifiedAt DateTime?
  createdAt    DateTime @default(now())

  // Last time an authenticated request resolved this user's session.
  // Updated throttled (≥5 min apart) from lib/auth/activity.ts; powers the
  // online/DAU/WAU/MAU counters on /admin/metrics.
  lastActiveAt DateTime?

  // AI provider preferences (override the env-wide default).
  // apiKey is stored verbatim for the demo; in prod, encrypt at rest.
  aiProvider String? // "kimi" | "openai" | "anthropic"
  aiModel    String?
  aiApiKey   String?

  // Moderation: a suspended user cannot log in or send proposals.
  // Set/cleared by admins from /admin/users.
  suspendedAt  DateTime?

  // ---- Roles + Monetization v1 ----
  role                       String   @default("member") // "member" | "swapl_admin"
  proposalsThisMonthCount    Int      @default(0)
  proposalsCounterResetAt    DateTime @default(now())
  hideSponsoredContent       Boolean  @default(false)

  // Social profile: interests are comma-separated slugs from
  // lib/interests.ts INTEREST_CATALOG (SQLite-friendly TEXT JSON array).
  interests                  String   @default("[]")
  bioVibe                    String?  // optional one-line "vibe" shown on /profile

  listings        Listing[]
  proposalsSent   SwapProposal[]  @relation("ProposalsSent")
  betaSignup      BetaSignup?
  reportsFiled    Report[]        @relation("ReportsFiled")
  reportsReceived Report[]        @relation("ReportsReceived")

  subscription    Subscription?
  invoices        BillingInvoice[]
  stripeCustomer  StripeCustomer?
  orderAddOns     OrderAddOn[]
  affiliateClicks AffiliateClick[]
  orgMemberships  OrganizationMember[]
  savedSearches   SavedSearch[]
  emailTokens     EmailToken[]
  authTokens      AuthToken[]
  devices         Device[]
  favorites       Favorite[]
}

// One-shot tokens for email verification + password reset. We store only the
// SHA-256 hash of the token; the cleartext is sent in the email URL exactly
// once and never persisted. Expired and used tokens stay in the table for
// short-term audit, then a daily cron sweeps them.
model EmailToken {
  id         String   @id @default(cuid())
  userId     String
  // "verify" -> email verification, "reset" -> password reset
  kind       String
  // SHA-256 hex of the random 32-byte token
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, kind])
  @@index([expiresAt])
}

// Mobile clients exchange credentials for an opaque bearer token; only the
// sha256 hash is persisted. Cookie sessions on the web are unaffected.
model AuthToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  platform   String                                          // "ios" | "android" | "web-pwa"
  appVersion String?
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// Push notification targets for a given user. One row per device per user.
model Device {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   String                                          // "ios" | "android"
  pushToken  String                                          // APNs token or FCM registration token
  locale     String?
  appVersion String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, pushToken])
  @@index([userId])
}

// ---------- LISTING ----------
// propertyType: APARTMENT | HOUSE | LOFT | TOWNHOUSE
// petTypes, photos, tags: JSON arrays of strings (SQLite has no array type).

model Listing {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String
  description    String

  propertyType   String
  city           String
  neighbourhood  String
  country        String
  address        String?
  lat            Float?
  lng            Float?

  sizeSqm        Int
  sleeps         Int
  bedrooms       Int
  bathrooms      Int
  floor          Int?

  hasElevator    Boolean  @default(false)
  stepFreeAccess Boolean  @default(false)

  petsAllowed    Boolean  @default(false)
  petTypes       String   @default("[]")

  wfhSetup       Boolean  @default(false)
  wfhDesks       Int      @default(0)

  hasParking     Boolean  @default(false)
  bikeIncluded   Boolean  @default(false)
  rooftop        Boolean  @default(false)
  balcony        Boolean  @default(false)
  garden         Boolean  @default(false)
  courtyard      Boolean  @default(false)
  piano          Boolean  @default(false)
  pool           Boolean  @default(false)
  gym            Boolean  @default(false)
  ac             Boolean  @default(false)
  dishwasher     Boolean  @default(false)
  washer         Boolean  @default(false)
  dryer          Boolean  @default(false)

  availableFrom  DateTime
  availableTo    DateTime
  minStayDays    Int      @default(3)
  maxStayDays    Int      @default(30)

  photos         String   @default("[]")
  tags           String   @default("[]")

  paletteHint    String?
  motifHint      String?  // legacy: comma-separated motif tags
  postcard       String?  // JSON-encoded Postcard composition (preferred over motifHint)

  // Trust + visibility (Feature 4)
  verificationStatus       String   @default("none")    // none | pending | approved | rejected
  verificationVideoUrl     String?
  verificationSubmittedAt  DateTime?
  verificationReviewedAt   DateTime?
  verificationReviewerId   String?
  isVerified               Boolean  @default(false)
  isFeatured               Boolean  @default(false)
  featuredUntil            DateTime?

  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proposalsAsProposer  SwapProposal[]  @relation("ProposerListing")
  proposalsAsTarget    SwapProposal[]  @relation("TargetListing")
  agreementsAsListing1 SwapAgreement[] @relation("AgreementListing1")
  agreementsAsListing2 SwapAgreement[] @relation("AgreementListing2")
  reports              Report[]
  verificationPayment  ListingVerificationPayment?
  featuredPurchases    ListingFeaturedPurchase[]
  favoritedBy          Favorite[]

  @@index([city])
  @@index([userId])
  @@index([isActive])
  @@index([isFeatured, featuredUntil])
  @@index([isVerified])
}

// ---------- FAVORITE ----------
// A user's wishlist of listings ("hearts" in the mobile apps).
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ---------- SWAP PROPOSAL ----------
// status: PENDING | ACCEPTED | DECLINED | COUNTERED | WITHDRAWN

model SwapProposal {
  id                String   @id @default(cuid())
  proposerId        String
  proposer          User     @relation("ProposalsSent", fields: [proposerId], references: [id], onDelete: Cascade)

  proposerListingId String
  proposerListing   Listing  @relation("ProposerListing", fields: [proposerListingId], references: [id], onDelete: Cascade)

  targetListingId   String
  targetListing     Listing  @relation("TargetListing", fields: [targetListingId], references: [id], onDelete: Cascade)

  dateFrom          DateTime
  dateTo            DateTime
  message           String?

  status            String   @default("PENDING")

  counterDateFrom   DateTime?
  counterDateTo     DateTime?
  counterMessage    String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agreement         SwapAgreement?
  messages          SwapMessage[]

  @@index([proposerId])
  @@index([targetListingId])
  @@index([status])
}

model SwapMessage {
  id         String       @id @default(cuid())
  proposalId String
  proposal   SwapProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  authorId   String
  body       String
  createdAt  DateTime     @default(now())
}

// ---------- SWAP AGREEMENT ----------
// status: ACTIVE | COMPLETED | INTERRUPTED

model SwapAgreement {
  id          String       @id @default(cuid())
  proposalId  String       @unique
  proposal    SwapProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  listing1Id  String
  listing1    Listing      @relation("AgreementListing1", fields: [listing1Id], references: [id])
  listing2Id  String
  listing2    Listing      @relation("AgreementListing2", fields: [listing2Id], references: [id])

  dateFrom    DateTime
  dateTo      DateTime

  keyCode1    String?
  keyCode2    String?

  status      String       @default("ACTIVE")

  // Set by the pre-trip reminder cron once the 48h heads-up has been sent
  // to both parties, so the sweep never double-sends.
  preTripReminderSentAt DateTime?

  insurancePolicy InsurancePolicy?
  orderAddOns     OrderAddOn[]

  createdAt   DateTime     @default(now())
}

model InsurancePolicy {
  id                 String        @id @default(cuid())
  agreementId        String        @unique
  agreement          SwapAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  provider           String        @default("swapl-cover")
  policyNumber       String
  coverageAmount     Int           @default(150000)

  // Feature 2 — partnership economics + lifecycle
  status             String        @default("active")  // pending | active | cancelled | claimed
  premiumCents       Int           @default(0)
  platformShareCents Int           @default(0)
  documentsUrl       String?
  externalId         String?

  expiresAt      DateTime
  createdAt      DateTime      @default(now())
}

model BetaSignup {
  id          String   @id @default(cuid())
  email       String   @unique
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])
  source      String?
  medium      String?
  campaign    String?
  term        String?
  content     String?
  landingPage String?
  referrer    String?
  invitedAt   DateTime?
  createdAt   DateTime @default(now())
}

model MarketingEvent {
  id          String   @id @default(cuid())
  eventName   String
  path        String?
  source      String?
  medium      String?
  campaign    String?
  term        String?
  content     String?
  referrer    String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([eventName, createdAt])
  @@index([campaign])
  @@index([source])
}

// Cached AI palette/motif decisions for cities not in the static catalog.
model CityArt {
  id        String   @id @default(cuid())
  city      String   @unique
  country   String?
  palette   String   // warm | cool | rose | sage | dusk | sand | mono
  motif     String?  // legacy: comma-separated motif keywords
  postcard  String?  // JSON-encoded Postcard composition
  source    String   @default("ai") // ai | fallback | manual | preset
  createdAt DateTime @default(now())
}

// Cached media sets per city, fetched server-side. kind="photo" rows hold
// real photos (Pexels / Unsplash / Wikimedia); kind="illustration" rows hold
// CC-licensed illustrations (Openverse / Pixabay). `photos` is a JSON-encoded
// array of normalized CityPhoto objects (lib/city-media). 30-day TTL.
model CityMedia {
  id        String   @id @default(cuid())
  city      String
  country   String
  photos    String   // JSON array of { url, width, height, alt, photographer?, photographerUrl?, sourceUrl?, provider }
  provider  String   // pexels | unsplash | wikimedia | openverse | pixabay
  kind      String   @default("photo") // photo | illustration
  fetchedAt DateTime @default(now())

  @@unique([city, country, kind])
}

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  reporter     User     @relation("ReportsFiled", fields: [reporterId], references: [id])
  targetUserId String?
  targetUser   User?    @relation("ReportsReceived", fields: [targetUserId], references: [id])
  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id])
  reason       String
  detail       String?
  // Moderation lifecycle: open | resolved | dismissed. Closed from
  // /admin/reports with an optional free-text resolution note.
  status       String   @default("open")
  resolution   String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime @default(now())

  @@index([status])
}

// =====================================================================
// Monetization v1 — Plans, Subscriptions, Add-ons, Affiliates, Corporate
// =====================================================================

// Feature 1 — Plan definitions (free | plus | pro). Seeded; not edited at runtime.
model Plan {
  id                 String  @id                       // "free" | "plus" | "pro"
  label              String
  monthlyCents       Int     @default(0)
  yearlyCents        Int     @default(0)
  stripePriceMonthly String?
  stripePriceYearly  String?

  // Mirrored in lib/billing/limits.ts so server checks stay statically typed.
  maxListings        Int     @default(0)               // 0 means unlimited
  maxProposalsMonth  Int     @default(0)               // 0 means unlimited
  prioritySearch     String  @default("standard")      // standard | priority | top
  fullFilters        Boolean @default(false)
  calendarSync       Boolean @default(false)
  matchBreakdown     Boolean @default(false)
  listingAnalytics   Boolean @default(false)
  multiHomeTeams     Boolean @default(false)

  subscriptions      Subscription[]
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  planId               String                                  // FK to Plan.id
  stripeCustomerId     String
  stripeSubscriptionId String?  @unique
  status               String                                  // active | past_due | canceled | trialing | unpaid | incomplete
  cancelAtPeriodEnd    Boolean  @default(false)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  source               String   @default("stripe")             // stripe | grandfather | dev_seed
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id])
  plan                 Plan     @relation(fields: [planId], references: [id])

  @@index([planId, status])
}

model StripeCustomer {
  id          String   @id @default(cuid())
  userId      String   @unique
  stripeId    String   @unique
  email       String
  taxId       String?
  countryCode String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model BillingEvent {
  id        String   @id @default(cuid())
  stripeId  String   @unique
  type      String
  payload   String   // raw JSON of the Stripe event
  createdAt DateTime @default(now())
}

model BillingInvoice {
  id              String   @id @default(cuid())
  userId          String
  stripeInvoiceId String   @unique
  amountCents     Int
  currency        String   @default("EUR")
  status          String                                       // paid | open | uncollectible | void
  pdfUrl          String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

// Feature 3 — Concierge add-ons
model AddOn {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  priceCents  Int
  currency    String   @default("EUR")
  type        String                                            // flat_fee | affiliate | included_in_plan
  provider    String                                            // keynest | airalo | skyscanner | swapl | ...
  category    String                                            // cleaning | lockbox | transfer | esim | guide
  isActive    Boolean  @default(true)
  metadata    String?
  createdAt   DateTime @default(now())

  orders      OrderAddOn[]
}

model OrderAddOn {
  id                    String   @id @default(cuid())
  userId                String
  agreementId           String
  addOnId               String
  status                String   @default("paid")              // paid | refunded | failed | clicked
  amountCents           Int
  stripePaymentIntentId String?
  notes                 String?
  createdAt             DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id])
  agreement SwapAgreement @relation(fields: [agreementId], references: [id])
  addOn     AddOn         @relation(fields: [addOnId], references: [id])

  @@index([userId])
  @@index([agreementId])
}

// Feature 4 — Verified Listing payment + Featured Placement purchases
model ListingVerificationPayment {
  id                    String   @id @default(cuid())
  listingId             String   @unique
  amountCents           Int
  stripePaymentIntentId String   @unique
  refunded              Boolean  @default(false)
  createdAt             DateTime @default(now())
  listing               Listing  @relation(fields: [listingId], references: [id])
}

model ListingFeaturedPurchase {
  id                    String   @id @default(cuid())
  listingId             String
  durationDays          Int                                     // 14 or 30
  amountCents           Int
  startsAt              DateTime
  endsAt                DateTime
  stripePaymentIntentId String   @unique
  refunded              Boolean  @default(false)
  createdAt             DateTime @default(now())
  listing               Listing  @relation(fields: [listingId], references: [id])

  @@index([listingId, endsAt])
}

// Feature 5 — Corporate B2B
model Organization {
  id                   String   @id @default(cuid())
  name                 String
  billingEmail         String
  stripeCustomerId     String?
  stripeSubscriptionId String?  @unique
  seatCount            Int      @default(5)
  planStatus           String   @default("active")              // active | past_due | canceled
  createdAt            DateTime @default(now())
  members              OrganizationMember[]
}

model OrganizationMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   @default("member")                         // admin | member
  invitedAt DateTime @default(now())
  joinedAt  DateTime?

  org  Organization @relation(fields: [orgId], references: [id])
  user User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@index([userId])
}

model CorporateLead {
  id            String   @id @default(cuid())
  companyName   String
  contactName   String
  email         String
  phone         String?
  employeeCount Int?
  useCase       String?
  status        String   @default("new")                        // new | contacted | won | lost
  createdAt     DateTime @default(now())
}

// Feature 6 — Affiliate revenue
model AffiliatePartner {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  category        String                                        // flights | esim | activities | insurance
  baseUrl         String
  trackingParam   String                                        // e.g. "aff_id"
  commissionModel String                                        // cpa | rev_share | percent_booking
  isActive        Boolean  @default(true)
  metadata        String?

  clicks          AffiliateClick[]
}

// Plus/Pro members can save filter presets and get a daily email digest of
// new matches.
model SavedSearch {
  id              String   @id @default(cuid())
  userId          String
  name            String
  query           String   // serialized URLSearchParams from /listings
  alertEnabled    Boolean  @default(true)
  lastNotifiedAt  DateTime?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AffiliateClick {
  id              String   @id @default(cuid())
  userId          String?
  agreementId     String?
  partnerSlug     String
  partnerId       String?
  destinationCity String?
  utmCampaign     String?
  clickedAt       DateTime @default(now())

  user    User?             @relation(fields: [userId], references: [id])
  partner AffiliatePartner? @relation(fields: [partnerId], references: [id])

  @@index([partnerSlug])
  @@index([destinationCity])
}
