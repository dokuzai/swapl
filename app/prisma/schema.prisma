// Optional owner-proof verification (DOK-162). A host may attach documents
// (deed, utility bill, etc.) to earn a "Verified owner" trust badge. This is
// NEVER a gate to publishing — it only sets Listing.ownerVerified when approved.
model PropertyVerification {
  id            String   @id @default(cuid())
  listingId     String
  userId        String
  status        String   @default("pending")   // pending | approved | rejected
  documents     String   @default("[]")        // JSON array of { url, label }
  reviewedById  String?
  note          String?
  // AI property-document analysis (DOK-186). Env-gated best-effort: when the AI
  // is unconfigured/not vision-capable these stay null and the flow degrades to
  // pure DOK-162 manual review. The AI only PROPOSES — admin confirms/overrides.
  // PRIVACY: we persist only the classification + entity type + bounded reasons
  // — never the titleholder name, the document content, or any other PII. The AI
  // reads an ownerName in-memory to match the host, but it is intentionally NOT
  // stored here; do not add an aiOwnerName column.
  aiClassification String? // private_owner | private_tenant | business | uncertain
  aiConfidence     Float?
  aiReasons        String? // JSON array of short strings (parseJSON)
  aiEntityType     String? // e.g. "person" | "company" | "agency" | "hotel"
  documentType     String? // deed | lease | other
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([listingId])
}

// Append-only log of the host's publish self-attestation (DOK-162). Captures
// the exact canonical text + version + mode the host agreed to at publish time.
model ListingPublishAck {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  ackText   String
  version   String
  mode      String?  // entire_home_while_away | room_or_host_present
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model AppFeedback {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("AppFeedbackAuthored", fields: [userId], references: [id], onDelete: Cascade)
  score      Int      // 1..5, validated at the API layer (SQLite has no CHECK via Prisma)
  comment    String?  // optional free text, ≤ 1000 chars (validated at API)
  // Client that submitted: "web" | "ios" | "android". Validated at the API layer.
  source     String
  // Which moment triggered this: "account" | "post-swap" | "post-review".
  surface    String   @default("account")
  // Stable key for the triggering context (e.g. agreement id) used to de-dupe
  // the no-re-nag rule. Empty string for the always-available account entry.
  contextKey String   @default("")
  // Free-form JSON CONTEXT, stored JSON-ENCODED as TEXT. Dual-schema rule:
  // MUST be `String` in BOTH schema.prisma and schema.postgres.prisma — never `Json`.
  context    String?
  createdAt  DateTime @default(now())

  @@unique([userId, surface, contextKey])
  @@index([userId])
  @@index([source])
  @@index([createdAt])
}
