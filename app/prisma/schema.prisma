// swapl — Prisma schema
// SQLite for local dev. Switch provider to "postgresql" + DATABASE_URL for prod.
// SQLite limitations honored: no native enums, no scalar arrays — both stored as JSON-encoded TEXT.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------- USER ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  // E.164 phone number, set when the user signs in via SMS OTP. Unique so a
  // phone maps to exactly one account (find-or-create key for phone login).
  phone        String?  @unique
  name         String?
  avatar       String?
  bio          String?
  passwordHash String?
  verified     Boolean  @default(false)
  // When the identity (KYC) check was approved. Source of truth is the
  // IdentityVerification rows; `verified` above is kept in sync (derived)
  // so existing queries/DTOs keep working unchanged.
  verifiedAt   DateTime?
  // Inbox-confirmed email. Distinct from `verified` (the listing-trust KYC
  // badge). Set when the user clicks the link in the verification email.
  emailVerifiedAt DateTime?
  createdAt    DateTime @default(now())

  // Last time an authenticated request resolved this user's session.
  // Updated throttled (≥5 min apart) from lib/auth/activity.ts; powers the
  // online/DAU/WAU/MAU counters on /admin/metrics.
  lastActiveAt DateTime?

  // AI provider preferences (override the env-wide default).
  // apiKey is encrypted at rest for new writes; run scripts/backfill-ai-api-keys.ts
  // once in deployed envs to rewrite legacy plaintext rows.
  aiProvider String? // "kimi" | "openai" | "anthropic"
  aiModel    String?
  aiApiKey   String?
  conversationReads ConversationRead[]

  // Moderation: a suspended user cannot log in or send proposals.
  // Set/cleared by admins from /admin/users.
  suspendedAt  DateTime?

  // ---- Roles + Monetization v1 ----
  role                       String   @default("member") // "member" | "swapl_admin"
  proposalsThisMonthCount    Int      @default(0)
  proposalsCounterResetAt    DateTime @default(now())
  hideSponsoredContent       Boolean  @default(false)

  // ---- Keys credit ledger (DOK-155) ----
  // Cached saldo: the KeysTransaction ledger is the source of truth; this is
  // kept in sync as the running sum and updated inside the same transaction
  // that appends a ledger row. "Travel points", never money — see lib/keys.
  keysBalance                Int      @default(0)

  // ---- Growth engine (DOK-157) ----
  // Short, shareable referral code minted lazily on first /api/referrals read
  // (or at signup). Unique so ?ref=CODE resolves to exactly one owner. The
  // referral economy earns KEYS, never money — see lib/growth.
  referralCode               String?  @unique

  // Social profile: interests are comma-separated slugs from
  // lib/interests.ts INTEREST_CATALOG (SQLite-friendly TEXT JSON array).
  interests                  String   @default("[]")
  bioVibe                    String?  // optional one-line "vibe" shown on /profile

  // Rich profile (DOK-147). All optional/additive for client back-compat.
  work        String?                 // occupation, free text
  languages   String?                 // JSON array of language codes/names
  homeCity    String?                 // shown on the public profile when settings.showHomeCity
  homeCountry String?

  // User settings, JSON-encoded TEXT (lib/settings.ts owns shape + defaults):
  // { searchEngineIndexing, showHomeCity, emailNotifications, pushNotifications }
  // null means "all defaults" — rows are only written on first change.
  settings    String?

  listings        Listing[]
  proposalsSent   SwapProposal[]  @relation("ProposalsSent")
  betaSignup      BetaSignup?
  reportsFiled    Report[]        @relation("ReportsFiled")
  reportsReceived Report[]        @relation("ReportsReceived")

  subscription    Subscription?
  invoices        BillingInvoice[]
  stripeCustomer  StripeCustomer?
  orderAddOns     OrderAddOn[]
  affiliateClicks AffiliateClick[]
  orgMemberships  OrganizationMember[]
  savedSearches   SavedSearch[]
  travelWindows   TravelWindow[]
  emailTokens     EmailToken[]
  authTokens      AuthToken[]
  devices         Device[]
  favorites       Favorite[]
  oauthAccounts   OAuthAccount[]
  webauthnCredentials WebAuthnCredential[]
  identityVerifications IdentityVerification[]
  propertyVerifications PropertyVerification[]
  publishAcks     ListingPublishAck[]
  travelProfile   TravelProfile?
  inspirationPackages InspirationPackage[]
  reviewsAuthored SwapReview[] @relation("ReviewsAuthored")
  reviewsReceived SwapReview[] @relation("ReviewsReceived")
  appFeedback  AppFeedback[] @relation("AppFeedbackAuthored")
  checkEvents     SwapCheckEvent[]
  disputesOpened   SwapDispute[]    @relation("DisputesOpened")
  disputesResolved SwapDispute[]    @relation("DisputesResolved")
  disputeMessages  DisputeMessage[]

  // Keys economy (DOK-155)
  keysTransactions KeysTransaction[]
  keysStaysAsGuest KeysStay[]       @relation("KeysStayGuest")
  keysStaysAsHost  KeysStay[]       @relation("KeysStayHost")

  // Growth engine (DOK-157)
  referralsOwned   Referral[] @relation("ReferralOwner")  // people I invited
  referralAsReferee Referral? @relation("ReferralReferee") // the row that brought me in

  // Share-attribution (DOK-164): listings I shared / share-conversions I made.
  shareAttributionsAsSharer    ListingShareAttribution[] @relation("ShareAttributionSharer")
  shareAttributionsAsConverter ListingShareAttribution[] @relation("ShareAttributionConverter")
}

// ---------- AI ASSISTANT (DOK-146) ----------

// AI-synthesised travel preference profile, built ONLY from in-app signals
// (interests, bio, favorites, saved searches, the user's own swap messages).
// Privacy-first: the user can read it (GET /api/assistant/profile) and delete
// it at any time (DELETE). Re-built on demand, never scraped from outside.
model TravelProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary     String                                              // human-readable synthesis shown to the user
  traits      String   @default("{}")                             // JSON: { themes[], cities[], vibe, constraints[] }
  sourcesUsed String   @default("[]")                             // JSON array, e.g. ["interests","favorites","saved_searches","swap_messages"]
  updatedAt   DateTime @updatedAt
}

// One "Get Inspired" package draft. payload is the full JSON the composer
// returned; on confirm the proposal is created through the same code path as
// POST /api/proposals and proposalId is stamped here.
model InspirationPackage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String   @default("draft")                      // "draft" | "confirmed" | "dismissed"
  payload         String                                          // JSON-encoded package (destination, alternatives, dates, affiliates, editable items)
  proposalId      String?                                         // set when the user confirms
  // Pay-on-accept (DOK-148): a SetupIntent saves the card at checkout; the
  // off-session PaymentIntent is created ONLY when the host accepts.
  setupIntentId   String?                                         // Stripe SetupIntent id (created at /checkout)
  paymentMethodId String?                                         // saved card, via setup_intent.succeeded webhook or recovered at confirm
  paymentStatus   String   @default("none")                       // "none" | "saved" | "charged" | "failed" | "canceled"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([proposalId])
}

// One identity (KYC) verification attempt at an external provider (Didit).
// A user may have several rows (declined/expired attempts followed by a
// retry); the latest row is the current state. On approval the webhook (or
// the polling fallback) stamps User.verified/verifiedAt.
model IdentityVerification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String    @default("didit")
  sessionId   String    @unique                                  // provider session id (Didit session_id)
  status      String    @default("pending")                      // "pending" | "approved" | "declined" | "expired"
  decision    String?                                            // raw provider decision payload (JSON-encoded TEXT)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
}

// External identity linked to a local user. One row per (provider, subject).
// Same-email sign-ins link to the existing account instead of duplicating it
// (only when the provider asserts the email as verified).
model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String                                         // "google" | "apple" | "telegram"
  providerUserId String                                         // Google sub | Apple sub | Telegram numeric id
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

// WebAuthn passkeys. publicKey is the COSE key base64url-encoded; counter is
// the authenticator's signature counter (BigInt — spec allows up to 2^32-1),
// bumped on every successful assertion and used to reject cloned credentials.
model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique                                 // base64url credential id from the authenticator
  publicKey    String                                            // base64url COSE public key
  counter      BigInt    @default(0)
  transports   String?                                           // JSON array, e.g. ["internal","hybrid"]
  deviceType   String?                                           // "singleDevice" | "multiDevice"
  backedUp     Boolean   @default(false)
  name         String?                                           // user-facing label, from the registering device
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

// Short-lived WebAuthn challenges (consume-and-delete, 5 min TTL). userId is
// set for registration (the challenge belongs to the logged-in account) and
// null for usernameless login (the credential resolves the user).
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique                                     // base64url challenge bytes
  userId    String?
  type      String                                               // "register" | "login"
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// One-time login codes (email or SMS). Only the SHA-256 hash of the 6-digit
// code is stored; codes expire after 10 minutes and allow max 5 attempts.
// Rows are keyed by destination (no userId — the user may not exist yet;
// verify does find-or-create).
model LoginOtp {
  id          String    @id @default(cuid())
  destination String                                            // normalised email or E.164 phone
  channel     String                                            // "email" | "sms"
  codeHash    String                                            // sha256 hex of the 6-digit code
  expiresAt   DateTime
  attempts    Int       @default(0)
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([destination])
}

// One-shot tokens for email verification + password reset. We store only the
// SHA-256 hash of the token; the cleartext is sent in the email URL exactly
// once and never persisted. Expired and used tokens stay in the table for
// short-term audit, then a daily cron sweeps them.
model EmailToken {
  id         String   @id @default(cuid())
  userId     String
  // "verify" -> email verification, "reset" -> password reset
  kind       String
  // SHA-256 hex of the random 32-byte token
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, kind])
  @@index([expiresAt])
}

// Mobile clients exchange credentials for an opaque bearer token; only the
// sha256 hash is persisted. Cookie sessions on the web are unaffected.
model AuthToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  platform   String                                          // "ios" | "android" | "web-pwa"
  appVersion String?
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// Push notification targets for a given user. One row per device per user.
model Device {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   String                                          // "ios" | "android"
  pushToken  String                                          // APNs token or FCM registration token
  locale     String?
  appVersion String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, pushToken])
  @@index([userId])
}

// ---------- LISTING ----------
// propertyType: APARTMENT | HOUSE | LOFT | TOWNHOUSE
// petTypes, photos, tags: JSON arrays of strings (SQLite has no array type).

model Listing {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String
  description    String

  propertyType   String
  city           String
  neighbourhood  String
  country        String
  address        String?
  lat            Float?
  lng            Float?

  sizeSqm        Int
  sleeps         Int
  bedrooms       Int
  bathrooms      Int
  floor          Int?

  hasElevator    Boolean  @default(false)
  stepFreeAccess Boolean  @default(false)

  petsAllowed    Boolean  @default(false)
  petTypes       String   @default("[]")

  wfhSetup       Boolean  @default(false)
  wfhDesks       Int      @default(0)

  hasParking     Boolean  @default(false)
  bikeIncluded   Boolean  @default(false)
  rooftop        Boolean  @default(false)
  balcony        Boolean  @default(false)
  garden         Boolean  @default(false)
  courtyard      Boolean  @default(false)
  piano          Boolean  @default(false)
  pool           Boolean  @default(false)
  gym            Boolean  @default(false)
  ac             Boolean  @default(false)
  dishwasher     Boolean  @default(false)
  washer         Boolean  @default(false)
  dryer          Boolean  @default(false)

  availableFrom  DateTime
  availableTo    DateTime
  minStayDays    Int      @default(3)
  maxStayDays    Int      @default(30)

  photos         String   @default("[]")
  tags           String   @default("[]")

  paletteHint    String?
  motifHint      String?  // legacy: comma-separated motif tags
  postcard       String?  // JSON-encoded Postcard composition (preferred over motifHint)

  // Trust + visibility (Feature 4)
  verificationStatus       String   @default("none")    // none | pending | approved | rejected
  verificationVideoUrl     String?
  verificationSubmittedAt  DateTime?
  verificationReviewedAt   DateTime?
  verificationReviewerId   String?
  isVerified               Boolean  @default(false)
  // Owner-proof trust badge (DOK-162): set true when a PropertyVerification is
  // approved by an admin. Distinct from isVerified (listing KYC, Feature 4) —
  // this attests the host owns/controls the home. Optional, never a publish gate.
  ownerVerified            Boolean  @default(false)
  // Eligibility gate (DOK-186): when the AI property-document analysis classifies
  // the proof as a BUSINESS/corporate property (hotel, agency, property manager,
  // company), the listing is flagged ineligible and excluded from public feeds
  // until an admin reverses it. Never deletes data — admin override is sovereign.
  ineligibleReason         String?  // e.g. "business_property"
  ineligibleAt             DateTime?
  isFeatured               Boolean  @default(false)
  featuredUntil            DateTime?

  // Keys economy (DOK-155): derived value-per-night in Keys, computed by
  // lib/keys/value.ts from size/sleeps/city-tier/verification. Cached here so
  // listing reads expose it without recomputation; recomputed on listing edits.
  nightlyKeys    Int?

  // What's offered (DOK-160): the whole home or just room(s) within it. A
  // private_room earns fewer Keys/night than entire_place; roomsOffered scales
  // a multi-room offer back up. Defaults keep every legacy row = whole home.
  spaceType      String   @default("entire_place") // entire_place | private_room
  roomsOffered   Int?     // # of rooms offered when spaceType=private_room (null/1 = one room)

  // Unified valuation v2 (DOK-163). The nightly value is split into a persisted
  // BASE (deterministic + AI feature signal + location tier) and a bounded
  // ADJUSTMENT (review feedback loop, ±20% of base). nightlyKeys above always
  // equals round(base*(1+adjustment)) clamped — recomputed periodically by the
  // listing-valuation cron, never synchronously on the read path.
  nightlyKeysBase       Int?    // pre-feedback value-per-night (base + tier + AI signal)
  nightlyKeysAdjustment Float?  // review feedback multiplier delta, clamped to [-0.20, +0.20]
  locationTier          Int?    // destination-desirability tier 1..5 (1 = most desirable)
  valuationExplanation  String? // JSON (parseJSON): structured factors + weights for the UI
  valuationUpdatedAt    DateTime? // last time the valuation cron recomputed this listing

  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proposalsAsProposer  SwapProposal[]  @relation("ProposerListing")
  proposalsAsTarget    SwapProposal[]  @relation("TargetListing")
  agreementsAsListing1 SwapAgreement[] @relation("AgreementListing1")
  agreementsAsListing2 SwapAgreement[] @relation("AgreementListing2")
  reports              Report[]
  verificationPayment  ListingVerificationPayment?
  featuredPurchases    ListingFeaturedPurchase[]
  favoritedBy          Favorite[]
  homeGuide            ListingHomeGuide?
  keysStays            KeysStay[]
  blockedRanges        ListingBlockedRange[]
  occupancies          ListingOccupancy[]
  propertyVerifications PropertyVerification[]
  publishAcks          ListingPublishAck[]
  shareAttributions    ListingShareAttribution[]

  @@index([city])
  @@index([userId])
  @@index([isActive])
  @@index([isFeatured, featuredUntil])
  @@index([isVerified])
}

// ---------- LOCATION TIER (DOK-163) ----------
// Per-city destination-desirability tier, used by the valuation engine AND the
// browse ranking. Persisted (not recomputed per read) and refreshed by the
// listing-valuation cron from a seeded baseline + optional AI desirability.
// Scale: tier 1 = world-magnet destinations … tier 5 = standard. The browse
// boost derived from this is deliberately small so tier-5 small towns stay
// visible (see lib/keys/location-tier.ts).
model LocationTier {
  id        String   @id @default(cuid())
  city      String   @unique // matched case-insensitively via normalized key
  tier      Int      // 1..5 (1 = most desirable)
  source    String   @default("seed") // seed | ai | manual
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ---------- FAVORITE ----------
// A user's wishlist of listings ("hearts" in the mobile apps).
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ---------- SWAP PROPOSAL ----------
// status: PENDING | ACCEPTED | DECLINED | COUNTERED | WITHDRAWN

model SwapProposal {
  id                String   @id @default(cuid())
  proposerId        String
  proposer          User     @relation("ProposalsSent", fields: [proposerId], references: [id], onDelete: Cascade)

  proposerListingId String
  proposerListing   Listing  @relation("ProposerListing", fields: [proposerListingId], references: [id], onDelete: Cascade)

  targetListingId   String
  targetListing     Listing  @relation("TargetListing", fields: [targetListingId], references: [id], onDelete: Cascade)

  dateFrom          DateTime
  dateTo            DateTime
  message           String?

  status            String   @default("PENDING")

  counterDateFrom   DateTime?
  counterDateTo     DateTime?
  counterMessage    String?

  // Per-party inbox archive (hide from my inbox without affecting the other side).
  proposerArchivedAt DateTime?
  targetArchivedAt   DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agreement         SwapAgreement?
  messages          SwapMessage[]
  participants      ConversationParticipant[]
  readCursors       ConversationRead[]

  @@index([proposerId])
  @@index([targetListingId])
  @@index([status])
}

model SwapMessage {
  id         String       @id @default(cuid())
  proposalId String
  proposal   SwapProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  authorId   String
  body       String
  photos     String       @default("[]")                  // JSON array of upload URLs
  readAt     DateTime?                                     // DEPRECATED (DOK-195): global per-message read flag. Read state is now per-recipient via ConversationRead; kept nullable for back-compat, no longer written.
  createdAt  DateTime     @default(now())

  @@index([proposalId, createdAt])
}

// Per (proposal, user) read cursor (DOK-195). Read state must be PER-RECIPIENT:
// in a multi-party thread (principals + guests) one participant reading must not
// clear another's unread state. `lastReadAt` is the high-water mark — a message
// is unread for this user iff it was authored by someone else and created after
// lastReadAt.
model ConversationRead {
  proposalId String
  proposal   SwapProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@id([proposalId, userId])
  @@index([userId])
}

// Per (proposal, recipient) throttle for new-message email notifications:
// push fires every message, but email is sent at most once per window so an
// active back-and-forth doesn't flood the inbox. lastEmailedAt is the last
// time we actually sent a notification email to this recipient for this thread.
model SwapMessageEmailThrottle {
  proposalId  String
  recipientId String
  lastEmailedAt DateTime @default(now())

  @@id([proposalId, recipientId])
}
// ---------- CONVERSATION PARTICIPANTS (DOK-187) ----------
// Multi-party swap conversation. The conversation is anchored to a
// SwapProposal (which carries the SwapAgreement once accepted). The two
// PRINCIPAL parties (proposer + target listing owner) are implicit — they are
// always allowed to read/post/act and can never be removed. Additional
// "guest_participant" rows let a principal pull co-travelers into the thread:
// they can READ and WRITE messages but can never act on the swap itself
// (accept/counter/decline/withdraw stay gated to the two principals).
//
// role:   "principal" | "guest_participant"
// status: "active" | "pending" | "removed"
// A guest invited by email lands as `pending` until that email registers/logs
// in, at which point it is materialised to `active` with the resolved userId.
model ConversationParticipant {
  id           String   @id @default(cuid())
  proposalId   String
  proposal     SwapProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // Resolved account once known. Email-only invites keep this null until the
  // invitee signs in with the invited address.
  userId       String?
  invitedEmail String?

  role         String   @default("guest_participant")
  status       String   @default("pending")

  invitedById  String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([proposalId, userId])
  @@unique([proposalId, invitedEmail])
  @@index([proposalId])
}


// ---------- SWAP AGREEMENT ----------
// status: ACTIVE | COMPLETED | INTERRUPTED

model SwapAgreement {
  id          String       @id @default(cuid())
  proposalId  String       @unique
  proposal    SwapProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  listing1Id  String
  listing1    Listing      @relation("AgreementListing1", fields: [listing1Id], references: [id])
  listing2Id  String
  listing2    Listing      @relation("AgreementListing2", fields: [listing2Id], references: [id])

  dateFrom    DateTime
  dateTo      DateTime

  keyCode1    String?
  keyCode2    String?

  status      String       @default("ACTIVE")

  // Set by the pre-trip reminder cron once the 48h heads-up has been sent
  // to both parties, so the sweep never double-sends.
  preTripReminderSentAt DateTime?

  // Set by the review-reminder cron once the "don't forget to review" nudge
  // has been sent, so the sweep never double-sends.
  reviewReminderSentAt DateTime?

  // Set by the daily cron once the T-7d "complete your home guide" nudge has
  // been sent to a party whose guide is still incomplete, so it never repeats.
  guideReminderSentAt DateTime?

  // Set the first time the day-of check-in nudge fires for an agreement with
  // no check-in yet, so the best-effort reminder is sent at most once.
  checkInNudgeSentAt DateTime?

  insurancePolicy InsurancePolicy?
  orderAddOns     OrderAddOn[]
  reviews         SwapReview[]
  checkEvents     SwapCheckEvent[]
  disputes        SwapDispute[]

  createdAt   DateTime     @default(now())
}

// ---------- HOME GUIDE (DOK-152) ----------
// One "Guida di casa" per listing — the owner fills it in; the other party of
// an active swap can read it only once the reveal gate opens (48h before the
// stay, or once both guides are complete). All fields optional; completeness is
// derived by counting valued "core" fields at the API layer.

model ListingHomeGuide {
  id                 String   @id @default(cuid())
  listingId          String   @unique
  listing            Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  accessInstructions String?
  keyPickup          String?
  wifiName           String?
  wifiPassword       String?
  heatingCooling     String?
  kitchen            String?
  bins               String?
  petsPlants         String?
  houseRules         String?
  neighbourhood      String?
  emergencyContact   String?
  updatedAt          DateTime @updatedAt
}

// ---------- CHECK-IN / CHECK-OUT (DOK-152) ----------
// One event per party per type. photos is a JSON-encoded array of upload URLs
// (SQLite has no array type). The check-in event derives the IN_PROGRESS phase.

model SwapCheckEvent {
  id          String        @id @default(cuid())
  agreementId String
  agreement   SwapAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String                                   // "checkin" | "checkout"
  note        String?
  photos      String        @default("[]")             // JSON array of upload URLs
  videoUrl    String?                                   // before/after condition video (audio baked in)
  createdAt   DateTime      @default(now())

  @@index([agreementId])
}

// ---------- DISPUTE / RESOLUTION CENTER (DOK-153) ----------
// A party of an agreement opens a SwapDispute; both parties and admins exchange
// DisputeMessages until an admin resolves/closes it. category drives the 24/7
// highlight (safety|access are urgent). status: open|investigating|
// awaiting_response|resolved|closed. photos are JSON arrays of upload URLs.

model SwapDispute {
  id           String        @id @default(cuid())
  agreementId  String
  agreement    SwapAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  openedById   String
  openedBy     User          @relation("DisputesOpened", fields: [openedById], references: [id])
  category     String                                   // access|damage|cleanliness|safety|no_show|other
  description  String
  photos       String        @default("[]")             // JSON array of upload URLs
  status       String        @default("open")           // open|investigating|awaiting_response|resolved|closed
  resolution   String?
  resolvedById String?
  resolvedBy   User?         @relation("DisputesResolved", fields: [resolvedById], references: [id])
  messages     DisputeMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([agreementId])
}

model DisputeMessage {
  id        String      @id @default(cuid())
  disputeId String
  dispute   SwapDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation(fields: [authorId], references: [id])
  body      String
  photos    String      @default("[]")                  // JSON array of upload URLs
  createdAt DateTime    @default(now())

  @@index([disputeId])
}

// ---------- SWAP REVIEW (DOK-147) ----------
// One review per party per COMPLETED agreement. author reviews subject (the
// other party of the swap). Aggregates power the public-profile stats.

model SwapReview {
  id          String        @id @default(cuid())
  agreementId String
  agreement   SwapAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  authorId    String
  author      User          @relation("ReviewsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     User          @relation("ReviewsReceived", fields: [subjectId], references: [id], onDelete: Cascade)
  rating      Int           // 1..5, validated at the API layer (SQLite has no CHECK via Prisma)
  text        String
  createdAt   DateTime      @default(now())

  // Moderation (DOK-149): hidden reviews are excluded from the public profile
  // and its aggregates; admins can restore them at any time.
  status        String    @default("published") // "published" | "hidden"
  moderatedAt   DateTime?
  moderatedById String?

  @@unique([agreementId, authorId])
  @@index([subjectId])
}

model InsurancePolicy {
  id                 String        @id @default(cuid())
  agreementId        String        @unique
  agreement          SwapAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  provider           String        @default("swapl-cover")
  policyNumber       String
  coverageAmount     Int           @default(150000)

  // Feature 2 — partnership economics + lifecycle
  status             String        @default("active")  // pending | active | cancelled | claimed
  premiumCents       Int           @default(0)
  platformShareCents Int           @default(0)
  documentsUrl       String?
  externalId         String?

  // DOK-156 — env-gated TON "proof-of-cover" notarization. Stores ONLY a tamper-
  // proof anchor of the certificate hash + minimal metadata (no personal data).
  // All fields stay null when the TON env is unset (anchoring is a no-op).
  onChainRef     String?       // tx hash / record address on TON
  onChainNetwork String?       // "testnet" | "mainnet"
  onChainStatus  String?       // "pending" | "anchored" | "failed" | null
  anchoredAt     DateTime?

  expiresAt      DateTime
  createdAt      DateTime      @default(now())
}

// ---------- KEYS CREDIT LEDGER (DOK-155) ----------
// Centralized, non-crypto "travel points" economy that sits ALONGSIDE the
// direct simultaneous swap (SwapProposal/SwapAgreement), never replacing it.
// The ledger is append-only and is the source of truth; User.keysBalance is a
// cached running sum updated in the same transaction (lib/keys/ledger.ts).
//
// Keys are NOT money: they cannot be bought, cashed out, or withdrawn. The
// only transfer is an in-app, capped "gift" between verified users — which
// keeps them in the "air-miles" exemption (no MiCA / e-money exposure).

model KeysTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Signed amount: positive credits, negative debits.
  delta       Int
  // earn_host | spend_stay | welcome_bonus | gift_sent | gift_received |
  // refund | hold | release | referral_bonus | invite_bonus |
  // earn_property_verified | earn_review | earn_share_converted | earn_listing_complete
  kind        String
  // The user's balance immediately after this row was applied (audit trail).
  balanceAfter Int
  // Optional link to the KeysStay that produced this row (hold/spend/earn/refund).
  stayId      String?
  note        String?
  // Deterministic idempotency key for one-shot EARN bonuses (DOK-164). A unique
  // string per (kind, real-world event) — e.g. "earn_review:<reviewId>" — so a
  // replayed event can never double-credit. Null for the high-frequency ledger
  // rows (hold/release/spend/earn_host/gift…) that aren't idempotency-guarded
  // here. Partial-unique semantics: many nulls allowed, non-null must be unique.
  eventKey    String?  @unique
  createdAt   DateTime @default(now())

  @@index([userId])
}

// A one-directional, NON-simultaneous booking paid in Keys. Distinct from
// SwapAgreement (which is a direct two-way swap). The guest spends Keys for
// nights at the host's listing; the host earns them. Keys are HELD when the
// stay is created (pending) and only become a real spend/earn on confirm.
model KeysStay {
  id                String   @id @default(cuid())
  listingId         String
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestId           String
  guest             User     @relation("KeysStayGuest", fields: [guestId], references: [id], onDelete: Cascade)
  hostId            String
  host              User     @relation("KeysStayHost", fields: [hostId], references: [id], onDelete: Cascade)

  dateFrom          DateTime
  dateTo            DateTime
  nights            Int
  keysCost          Int

  // pending | confirmed | declined | cancelled | completed
  status            String   @default("pending")

  // Set on confirm when lib/insurance issues a cover policy for the stay.
  insurancePolicyId String?

  createdAt         DateTime @default(now())

  @@index([listingId])
  @@index([guestId])
  @@index([hostId])
  @@index([status])
}

// ---------- LISTING BLOCKED RANGE (DOK-159) ----------
// A host-defined date range during which the listing is unavailable, on top of
// the implicit blocks from active swap agreements and pending/confirmed Keys
// stays. Used by lib/listing/availability.ts to subtract manual blocks from the
// published availability window.
model ListingBlockedRange {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  dateFrom  DateTime
  dateTo    DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([listingId])
}

// Authoritative occupancy ledger for availability writes. Every active
// agreement, pending/confirmed Keys stay, and host block writes rows here in
// the same transaction as its source row. In Postgres, production additionally
// applies an exclusion constraint over (listingId, date range) via
// scripts/apply-postgres-availability-constraints.ts.
model ListingOccupancy {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  source    String   // "swap_agreement" | "keys_stay" | "blocked_range"
  sourceId  String
  dateFrom  DateTime
  dateTo    DateTime
  createdAt DateTime @default(now())

  @@unique([source, sourceId, listingId])
  @@index([listingId, dateFrom, dateTo])
}

// ---------- GROWTH ENGINE / REFERRALS (DOK-157) ----------
// One referral edge. Created `pending` at signup-with-?ref=CODE or when a host
// issues an invite-to-stay; the refereeId is linked when the invitee's account
// is created (email/registration match). It becomes `qualified` (and Keys are
// credited to BOTH sides exactly once) when the invitee VERIFIES their identity
// — the anti-farm gate. `rewarded` means the two-sided Keys reward was issued
// (a referral past the daily/monthly cap stays `qualified`, no Keys, but still
// counts toward waitlist position + leaderboard).
//
// Referral rewards are emitted through the Keys ledger (kinds referral_bonus /
// invite_bonus), idempotent per Referral (one rewardedAt stamp guards it).
model Referral {
  id            String   @id @default(cuid())
  ownerId       String
  owner         User     @relation("ReferralOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // Linked once the invitee's account exists. Unique: a user can be referred by
  // at most one owner (the first attribution wins).
  refereeId     String?  @unique
  referee       User?    @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: SetNull)
  // Captured at invite-to-stay time when no account exists yet; used to link
  // refereeId on registration.
  refereeEmail  String?
  source        String   @default("link")              // link | invite_to_stay
  // For invite_to_stay: the host's listing the invitation is tied to.
  listingId     String?
  // Opaque token for invite-to-stay links (?invite=TOKEN). Null for plain ?ref.
  token         String?  @unique
  status        String   @default("pending")           // pending | qualified | rewarded
  // Idempotency guard for the two-sided Keys reward.
  rewardedAt    DateTime?
  createdAt     DateTime @default(now())
  qualifiedAt   DateTime?
  // Set once the REFERRER (owner) has seen the "you earned Keys" credit for this
  // referral — drives the real-time referrer toast (DOK-157). Null while the
  // credit is still unseen; a polling endpoint reads unseen rows and stamps it.
  ownerNotifiedAt DateTime?

  @@index([ownerId])
  @@index([refereeEmail])
}

// ---------- LISTING SHARE ATTRIBUTION (DOK-164) ----------
// Minimal share→conversion attribution: when a user shares a listing they get a
// short share token (?s=TOKEN on the listing link). The first time a NEW guest
// who arrived via that token actually books/swaps that listing, the sharer earns
// a one-time `earn_share_converted` bonus (identity-gated, idempotent, capped).
//
// One row per (listing, sharer) — re-sharing reuses the same token. `convertedAt`
// + `keysAwardedAt` are the idempotency guards: a conversion is recorded once and
// the Keys bonus is credited once, even if the booking event is replayed.
model ListingShareAttribution {
  id           String   @id @default(cuid())
  listingId    String
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // The user who shared the listing (earns the bonus on conversion).
  sharerId     String
  sharer       User     @relation("ShareAttributionSharer", fields: [sharerId], references: [id], onDelete: Cascade)
  // Opaque token embedded in the share link (?s=TOKEN).
  token        String   @unique
  // The guest who converted (booked/swapped) via this share, set once.
  convertedById String?
  convertedBy   User?    @relation("ShareAttributionConverter", fields: [convertedById], references: [id], onDelete: SetNull)
  // The KeysStay or SwapAgreement id that realised the conversion (audit).
  conversionRef String?
  convertedAt   DateTime?
  // Stamped when the sharer's Keys bonus was credited (idempotency guard).
  keysAwardedAt DateTime?
  createdAt     DateTime @default(now())

  @@unique([listingId, sharerId])
  @@index([sharerId])
}

model BetaSignup {
  id          String   @id @default(cuid())
  email       String   @unique
