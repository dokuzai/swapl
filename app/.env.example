# swapl — environment variables
#
# Copy to `.env.local` for development. In production these are set in the
# Vercel project (Settings → Environment Variables), NOT committed.
#
# The app degrades gracefully when an integration is unconfigured:
#   - Stripe missing      → billing endpoints return 503 "Available soon"
#   - INSURANCE_PROVIDER  → falls back to the built-in mock underwriter
#   - AI keys missing     → AI features fall back to templates
# So only DATABASE_URL + SESSION_SECRET are strictly required to boot.

# ── Core ──────────────────────────────────────────────────────────────────
# Dev uses SQLite; prod (Vercel) uses Postgres and the schema.postgres.prisma
# client. On Vercel set this to your Postgres connection string.
DATABASE_URL="file:./dev.db"
# Min 32 random bytes — signs the web session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=
# Public base URL, used in emails and absolute links (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Shared secret guarding the /api/cron/* endpoints (sent by the Vercel cron).
CRON_SECRET=

# ── Billing (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for subscriptions + one-time add-ons (create in the Stripe dashboard).
STRIPE_PRICE_CORPORATE_SEAT=
STRIPE_PRICE_VERIFY_LISTING=
STRIPE_PRICE_ADDON_CLEANING=
STRIPE_PRICE_ADDON_LOCKBOX=
STRIPE_PRICE_ADDON_CITY_GUIDE=

# ── Insurance ───────────────────────────────────────────────────────────────
# "mock" (default) uses the built-in deterministic underwriter. Set to the real
# provider id once an underwriter ships and its adapter is added to
# lib/insurance/index.ts.
INSURANCE_PROVIDER="mock"

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender, e.g. "swapl <hello@swapl.com>"
RESEND_FROM=

# ── AI content generation ─────────────────────────────────────────────────
# AI_PROVIDER selects the backend: "anthropic" | "openai" | "kimi".
# Generic overrides (AI_API_KEY / AI_MODEL) win when set; otherwise the
# provider-specific keys below are used.
AI_PROVIDER="anthropic"
AI_API_KEY=
AI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
KIMI_API_KEY=
KIMI_BASE_URL=
MOONSHOT_API_KEY=

# ── Push notifications (Firebase Cloud Messaging) ──────────────────────────
# The full service-account JSON, single-line (used by iOS + Android push).
FCM_SERVICE_ACCOUNT_JSON=

# ── Affiliate partner ids (post-swap recommendations) ──────────────────────
AFF_SKYSCANNER_ID=
AFF_BATTLEFACE_ID=
AFF_GETYOURGUIDE_ID=
AFF_AIRALO_ID=

# ── Database migration helper (scripts/ only, one-off) ─────────────────────
# Used by the SQLite→Postgres copy script; leave unset in normal operation.
DATABASE_URL_SOURCE=
DATABASE_URL_TARGET=
