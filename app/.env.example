# swapl — environment variables
#
# Copy to `.env.local` for development. In production these are set in the
# Vercel project (Settings → Environment Variables), NOT committed.
#
# The app degrades gracefully when an integration is unconfigured:
#   - Stripe missing      → billing endpoints return 503 "Available soon"
#   - INSURANCE_PROVIDER  → falls back to the built-in mock underwriter
#   - AI keys missing     → AI features fall back to templates
# So only DATABASE_URL + SESSION_SECRET are strictly required to boot.

# ── Core ──────────────────────────────────────────────────────────────────
# Dev uses SQLite; prod (Vercel) uses Postgres and the schema.postgres.prisma
# client. On Vercel set this to your Postgres connection string.
DATABASE_URL="file:./dev.db"
# Min 32 random bytes — signs the web session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=
# Public base URL, used in emails and absolute links (no trailing slash).
# Production: https://swapl.fun (set in Vercel env vars).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Shared secret guarding the /api/cron/* endpoints (sent by the Vercel cron).
CRON_SECRET=

# ── Observability (Sentry) ──────────────────────────────────────────────────
# Backend error tracking, env-gated: when unset every capture is a no-op and
# @sentry/node is never loaded. Server-side only — no client bundles.
SENTRY_DSN=

# ── Billing (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for subscriptions + one-time add-ons (create in the Stripe dashboard).
STRIPE_PRICE_CORPORATE_SEAT=
STRIPE_PRICE_VERIFY_LISTING=
STRIPE_PRICE_ADDON_CLEANING=
STRIPE_PRICE_ADDON_LOCKBOX=
STRIPE_PRICE_ADDON_CITY_GUIDE=

# ── Insurance ───────────────────────────────────────────────────────────────
# "mock" (default) uses the built-in deterministic underwriter. Set to the real
# provider id once an underwriter ships and its adapter is added to
# lib/insurance/index.ts.
INSURANCE_PROVIDER="mock"

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender, e.g. "swapl <hello@swapl.com>"
RESEND_FROM=

# ── Multi-provider auth (Google / Apple / Telegram / SMS OTP) ──────────────
# Everything here is env-gated: when unset, the matching endpoint returns 503
# and GET /api/auth/providers reports the provider as disabled so clients hide
# the button. Email OTP needs no extra config (uses Resend / console fallback).
#
# Google Sign-In: comma-separated OAuth client IDs whose ID tokens we accept
# (web client id, iOS client id, Android client id — from Google Cloud Console).
GOOGLE_OAUTH_CLIENT_IDS=
# Sign in with Apple: comma-separated audiences we accept in the identity
# token (the app bundle id, e.g. fun.swapl.app, plus the web Services ID).
APPLE_SIGNIN_BUNDLE_IDS=
# Telegram Login Widget: bot token (verifies the HMAC of the auth payload)
# and the bot's public @username (returned to clients to render the widget).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# SMS one-time codes via Twilio (REST API, no SDK). All three required;
# unset → phone login disabled in prod, console-logged codes in dev.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender: an E.164 number or an approved alphanumeric sender id.
TWILIO_FROM=

# ── AI content generation ─────────────────────────────────────────────────
# AI_PROVIDER selects the backend: "anthropic" | "openai" | "kimi".
# Generic overrides (AI_API_KEY / AI_MODEL) win when set; otherwise the
# provider-specific keys below are used.
AI_PROVIDER="anthropic"
AI_API_KEY=
AI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
KIMI_API_KEY=
KIMI_BASE_URL=
MOONSHOT_API_KEY=

# ── Push notifications (Firebase Cloud Messaging) ──────────────────────────
# The full service-account JSON, single-line (used by iOS + Android push).
FCM_SERVICE_ACCOUNT_JSON=

# ── City media (real city photos: listing hero, browse cards, Discover) ────
# Provider selection: "pexels" | "unsplash" | "wikimedia". When unset,
# defaults to pexels if PEXELS_API_KEY is present, otherwise the keyless
# wikimedia provider. Photos are cached per city in the CityMedia table for
# 30 days; keys stay server-side only.
CITY_MEDIA_PROVIDER=
# Pexels API key — free at https://www.pexels.com/api/ (requires visible
# "Photo: {name} / Pexels" attribution, which the gallery renders).
PEXELS_API_KEY=
# Unsplash access key — https://unsplash.com/developers (stub-ready provider).
UNSPLASH_ACCESS_KEY=
# Optional: Pixabay API key — https://pixabay.com/api/docs/ — secondary source
# for the listing-hero city ILLUSTRATIONS (primary is the keyless Openverse).
PIXABAY_API_KEY=

# ── Affiliate partner ids (post-swap recommendations) ──────────────────────
AFF_SKYSCANNER_ID=
AFF_BATTLEFACE_ID=
AFF_GETYOURGUIDE_ID=
AFF_AIRALO_ID=

# ── Database migration helper (scripts/ only, one-off) ─────────────────────
# Used by the SQLite→Postgres copy script; leave unset in normal operation.
DATABASE_URL_SOURCE=
DATABASE_URL_TARGET=
