{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:pg-availability-constraints": "tsx scripts/apply-postgres-availability-constraints.ts",
    "vercel-build": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "postinstall": "node -e \"const s=process.env.VERCEL?'prisma/schema.postgres.prisma':'prisma/schema.prisma';require('child_process').execSync('prisma generate --schema '+s,{stdio:'inherit'})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.2.2",
