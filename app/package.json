    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.3.0-canary.8",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "next": "16.3.0-canary.8"
  },
  "packageManager": "pnpm@10.18.3"
}
