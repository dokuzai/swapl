    <!-- Optional "Verify ownership" entry -->
    <string name="owner_verify_cta">Verified owner badge — optional</string>
    <string name="owner_verify_cta_pending">Verified owner badge — in review</string>
    <string name="owner_verify_cta_rejected">Verified owner badge — try again</string>
    <string name="owner_verify_optional_note">A trust boost for guests. Never required to publish or swap.</string>
    <string name="owner_verify_title">Verify ownership</string>
    <string name="owner_verify_explainer">Add a document that shows your right to this home — a deed or visura, or a lease in your name. An admin reviews it and, once approved, your listing shows a \"Verified owner\" badge.</string>
    <string name="owner_verify_ai_explainer">A quick AI check reads the document first to confirm it matches this home. A person on our team always has the final say.</string>
    <string name="owner_verify_tenant_note">Renting is welcome. If you rent and your lease lets you host, you\'re fully eligible — you don\'t need to own the home.</string>
    <string name="owner_verify_tenant">Renting? You\'re welcome here too — upload your lease instead of a deed. You can host on Swapl as long as your rental contract lets you have guests.</string>
    <string name="owner_verify_privacy_note">We don\'t store your document after the check. Only the AI reads your personal details, and we keep just whether it shows a private home — never your ID, address, or the document itself.</string>
    <string name="owner_verify_privacy">Your document is read once to check the home is yours, then it isn\'t stored — we keep only the result (verified or not), never the document or its contents.</string>
    <string name="owner_verify_private_only_note">Swapl is a swap between private people, so company or commercial properties can\'t be listed here.</string>
    <string name="owner_verify_doc_type_label">What are you uploading? (optional)</string>
    <string name="owner_verify_doc_type_deed">Deed / visura</string>
    <string name="owner_verify_doc_type_lease">Lease</string>
    <string name="owner_verify_status_pending">Your last submission is in review. A person on our team makes the final call — usually within 2 business days. If our automated check was unsure it can take a little longer, but you\'re not stuck: we always follow up.</string>
    <string name="owner_verify_status_rejected">Your last submission wasn\'t approved. Add a clearer document and resubmit.</string>
    <string name="owner_verify_business_title">Our check suggests this may be a commercial property — we may have it wrong</string>
    <string name="owner_verify_business_body">Our automated check read your document as a company or commercial property, and Swapl is a swap between private people. But automated checks aren\'t perfect, and a real person — never the AI — makes the final decision. If this is your own home, get in touch: a person on our team reviews these personally, usually within 2 business days, and a lease, deed, or tax record in your name is enough to set it straight.</string>
